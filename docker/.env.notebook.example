# Notebook-side environment variables for ONLYOFFICE + Cloudflare Tunnel
#
# Usage:
#   cp docker/.env.notebook.example docker/.env.notebook
#   # Fill in both values, then:
#   docker compose -f docker/docker-compose.notebook.yml --env-file docker/.env.notebook up -d
#
# These two vars are the ONLY things you need to run ONLYOFFICE on your notebook.

# ── Shared JWT secret ─────────────────────────────────────────────────────────
# Must be identical to ONLYOFFICE_JWT_SECRET in the ERP app (Vercel/Render env vars).
# Generate with:  openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=paste_your_shared_jwt_secret_here

# ── Cloudflare Tunnel token ───────────────────────────────────────────────────
# Copy from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure
# (The long token that starts with "eyJ...")
CLOUDFLARE_TUNNEL_TOKEN=paste_your_tunnel_token_here
