model MoveOut {
  id                String           @id @default(uuid())
  contractId        String           @unique
  moveOutDate       DateTime       @db.Date
  depositAmount     Decimal          @db.Decimal(12, 2)
  totalDeduction   Decimal          @default(0) @db.Decimal(12, 2)
  finalRefund       Decimal          @default(0) @db.Decimal(12, 2)
  status            MoveOutStatus    @default(PENDING)
  notes             String?
  lineNoticeSentAt  DateTime? @db.Timestamptz(6)
  confirmedAt       DateTime? @db.Timestamptz(6)
  confirmedBy       String?
  refundAt          DateTime? @db.Timestamptz(6)
  refundBy          String?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)
  contract          Contract         @relation(fields: [contractId], references: [id])
  items             MoveOutItem[]

  @@index([status])
  @@index([moveOutDate])
  @@index([contractId])
  @@map("move_outs")
}

model MoveOutItem {
  id            String               @id @default(uuid())
  moveOutId     String
  category      String               // wall, floor, bathroom, kitchen, furniture, other
  item          String               // paint, tiles, faucet, bed, wardrobe, etc.
  condition     MoveOutItemCondition
  cost          Decimal              @default(0) @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  moveOut       MoveOut              @relation(fields: [moveOutId], references: [id], onDelete: Cascade)

  @@index([moveOutId])
  @@map("move_out_items")
}
