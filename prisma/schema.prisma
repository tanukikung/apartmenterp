generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BankAccount {
  id                  String               @id
  name                String
  bankName            String
  bankAccountNo       String
  promptpay           String?
  active              Boolean              @default(true)
  paymentTransactions PaymentTransaction[] @relation("TransactionBankAccount")
  rooms               Room[]               @relation("RoomDefaultAccount")

  @@map("bank_accounts")
}

model BillingRule {
  code                     String         @id
  descriptionTh            String
  waterEnabled             Boolean
  waterUnitPrice           Decimal        @db.Decimal(10, 2)
  waterMinCharge           Decimal        @db.Decimal(10, 2)
  waterServiceFeeMode      ServiceFeeMode
  waterServiceFeeAmount    Decimal        @db.Decimal(10, 2)
  electricEnabled          Boolean
  electricUnitPrice        Decimal        @db.Decimal(10, 2)
  electricMinCharge        Decimal        @db.Decimal(10, 2)
  electricServiceFeeMode   ServiceFeeMode
  electricServiceFeeAmount Decimal        @db.Decimal(10, 2)
  penaltyPerDay            Decimal         @default(0) @db.Decimal(10, 2)
  maxPenalty               Decimal         @default(0) @db.Decimal(10, 2)
  gracePeriodDays          Int             @default(0)
  roomBillings             RoomBilling[]  @relation("RoomBillingRule")
  rooms                    Room[]         @relation("RoomDefaultRule")

  @@map("billing_rules")
}

model Expense {
  id          String         @id @default(uuid())
  category    ExpenseCategory
  amount      Decimal        @db.Decimal(12, 2)
  date        DateTime       @db.Date
  description String         @db.Text
  paidTo      String?
  receiptNo   String?
  createdBy   String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([category])
  @@index([date])
  @@index([createdAt])
  @@map("expenses")
}

model Room {
  roomNo                    String                     @id
  floorNo                   Int
  defaultAccountId          String
  defaultRuleCode           String
  defaultRentAmount         Decimal                    @db.Decimal(10, 2)
  hasFurniture              Boolean                    @default(false)
  defaultFurnitureAmount    Decimal                    @default(0) @db.Decimal(10, 2)
  roomStatus                RoomStatus                 @default(VACANT)
  maxResidents              Int                        @default(2)
  lineUserId                String?
  contracts                 Contract[]
  conversations             Conversation[]
  documentGenerationTargets DocumentGenerationTarget[]
  generatedDocuments        GeneratedDocument[]
  invoices                  Invoice[]
  maintenanceTickets        MaintenanceTicket[]
  billings                  RoomBilling[]
  tenants                   RoomTenant[]
  deliveryOrderItems        DeliveryOrderItem[]
  defaultAccount            BankAccount                @relation("RoomDefaultAccount", fields: [defaultAccountId], references: [id])
  defaultRule               BillingRule                @relation("RoomDefaultRule", fields: [defaultRuleCode], references: [code])

  @@index([floorNo])
  @@index([roomStatus])
  @@index([defaultAccountId])
  @@map("rooms")
}

model BillingPeriod {
  id            String              @id @default(uuid())
  year          Int
  month         Int
  status        BillingPeriodStatus @default(OPEN)
  dueDay        Int                 @default(25)
  note          String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  importBatches ImportBatch[]
  roomBillings  RoomBilling[]

  @@unique([year, month])
  @@index([status])
  @@index([year, month])
  @@map("billing_periods")
}

model RoomBilling {
  id                       String            @id @default(uuid())
  billingPeriodId          String
  roomNo                   String
  recvAccountOverrideId    String?
  recvAccountId            String
  ruleOverrideCode         String?
  ruleCode                 String
  rentAmount               Decimal           @db.Decimal(10, 2)
  waterMode                MeterMode
  waterPrev                Decimal?          @db.Decimal(10, 2)
  waterCurr                Decimal?          @db.Decimal(10, 2)
  waterUnitsManual         Decimal?          @db.Decimal(10, 2)
  waterUnits               Decimal           @default(0) @db.Decimal(10, 2)
  waterUsageCharge         Decimal           @default(0) @db.Decimal(10, 2)
  waterServiceFeeManual    Decimal?          @db.Decimal(10, 2)
  waterServiceFee          Decimal           @default(0) @db.Decimal(10, 2)
  waterTotal               Decimal           @default(0) @db.Decimal(10, 2)
  electricMode             MeterMode
  electricPrev             Decimal?          @db.Decimal(10, 2)
  electricCurr             Decimal?          @db.Decimal(10, 2)
  electricUnitsManual      Decimal?          @db.Decimal(10, 2)
  electricUnits            Decimal           @default(0) @db.Decimal(10, 2)
  electricUsageCharge      Decimal           @default(0) @db.Decimal(10, 2)
  electricServiceFeeManual Decimal?          @db.Decimal(10, 2)
  electricServiceFee       Decimal           @default(0) @db.Decimal(10, 2)
  electricTotal            Decimal           @default(0) @db.Decimal(10, 2)
  furnitureFee             Decimal           @default(0) @db.Decimal(10, 2)
  otherFee                 Decimal           @default(0) @db.Decimal(10, 2)
  totalDue                 Decimal           @default(0) @db.Decimal(10, 2)
  note                     String?
  checkNotes               String?
  status                   RoomBillingStatus @default(DRAFT)
  calculatedAt             DateTime? @db.Timestamptz(6)
  createdAt                DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime @updatedAt @db.Timestamptz(6)
  invoice                  Invoice?
  billingPeriod            BillingPeriod     @relation(fields: [billingPeriodId], references: [id])
  room                     Room              @relation(fields: [roomNo], references: [roomNo])
  effectiveRule            BillingRule       @relation("RoomBillingRule", fields: [ruleCode], references: [code])

  @@unique([billingPeriodId, roomNo])
  @@index([billingPeriodId])
  @@index([roomNo])
  @@index([status])
  @@index([ruleCode])
  @@index([calculatedAt])
  @@map("room_billings")
}

model Invoice {
  id                        String                     @id @default(uuid())
  roomBillingId             String                     @unique
  roomNo                    String
  year                      Int
  month                     Int
  status                    InvoiceStatus              @default(GENERATED)
  totalAmount               Decimal                    @db.Decimal(10, 2)
  lateFeeAmount             Decimal                    @default(0) @db.Decimal(10, 2)
  lateFeeAppliedAt          DateTime? @db.Timestamptz(6)
  dueDate                   DateTime @db.Timestamptz(6)
  issuedAt                  DateTime @default(now()) @db.Timestamptz(6)
  sentAt                    DateTime? @db.Timestamptz(6)
  paidAt                    DateTime? @db.Timestamptz(6)
  note                      String?
  accessToken               String?                    @unique
  createdAt                 DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @db.Timestamptz(6)
  documentGenerationTargets DocumentGenerationTarget[]
  generatedDocuments        GeneratedDocument[]
  deliveries                InvoiceDelivery[]
  roomBilling               RoomBilling                @relation(fields: [roomBillingId], references: [id])
  room                      Room                       @relation(fields: [roomNo], references: [roomNo])
  paymentMatches            PaymentMatch[]
  paymentTransactions       PaymentTransaction[]       @relation("InvoicePaymentTransactions")
  payments                  Payment[]                  @relation("InvoiceToPayment")
  deliveryOrderItems        DeliveryOrderItem[]

  @@index([roomNo])
  @@index([year, month])
  @@index([roomNo, year, month])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceDelivery {
  id                   String                 @id @default(uuid())
  invoiceId            String
  channel              InvoiceDeliveryChannel
  status               InvoiceDeliveryStatus  @default(PENDING)
  recipientRef         String?
  sentAt               DateTime? @db.Timestamptz(6)
  viewedAt             DateTime? @db.Timestamptz(6)
  errorMessage         String?
  createdBy            String?
  documentTemplateId   String?
  documentTemplateHash String?
  createdAt            DateTime @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @db.Timestamptz(6)
  invoice              Invoice                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([channel, status])
  @@map("invoice_deliveries")
}

model ImportBatch {
  id              String            @id @default(uuid())
  billingPeriodId String
  filename        String
  schemaVersion   String
  rowsTotal       Int
  rowsImported    Int
  rowsSkipped     Int
  rowsErrored     Int
  status          ImportBatchStatus
  errorLog        Json?
  importedBy      String
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  billingPeriod   BillingPeriod     @relation(fields: [billingPeriodId], references: [id])

  @@index([billingPeriodId])
  @@index([status])
  @@map("import_batches")
}

model Payment {
  id               String         @id @default(uuid())
  amount           Decimal        @db.Decimal(12, 2)
  paidAt           DateTime @db.Timestamptz(6)
  description      String?
  reference        String?
  sourceFile       String
  status           PaymentStatus  @default(PENDING)
  matchedInvoiceId String?
  matchedAt        DateTime? @db.Timestamptz(6)
  confirmedAt      DateTime? @db.Timestamptz(6)
  confirmedBy      String?
  rejectedAt       DateTime? @db.Timestamptz(6)
  rejectedBy       String?
  rejectReason     String?
  remark           String?  // admin note, e.g. "Overpayment credit: excess of X THB"
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)
  matches          PaymentMatch[]
  invoices         Invoice[]      @relation("InvoiceToPayment")

  @@index([status])
  @@index([paidAt])
  @@index([amount])
  @@index([matchedInvoiceId])
  @@map("payments")
}

model PaymentTransaction {
  id              String                   @id @default(uuid())
  amount          Decimal                  @db.Decimal(12, 2)
  transactionDate DateTime @db.Timestamptz(6)
  roomNo          String?
  description     String?
  reference       String?
  sourceFile      String
  status          PaymentTransactionStatus @default(PENDING)
  confidenceScore Decimal?                 @db.Decimal(3, 2)
  invoiceId       String?
  matchedAt       DateTime? @db.Timestamptz(6)
  confirmedAt     DateTime? @db.Timestamptz(6)
  confirmedBy     String?
  rejectedAt      DateTime? @db.Timestamptz(6)
  rejectedBy      String?
  rejectReason    String?
  bankAccountId   String?
  matchedAmount   Decimal?                 @db.Decimal(12, 2)
  matchType       PaymentMatchType?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)
  bankAccount     BankAccount?             @relation("TransactionBankAccount", fields: [bankAccountId], references: [id])
  invoice         Invoice?                 @relation("InvoicePaymentTransactions", fields: [invoiceId], references: [id])

  @@unique([transactionDate, amount, roomNo], name: "PaymentTransaction_dedup")
  @@index([status])
  @@index([roomNo])
  @@index([transactionDate])
  @@index([amount])
  @@index([reference])
  @@index([bankAccountId])
  @@map("payment_transactions")
}

model PaymentMatch {
  id            String             @id @default(uuid())
  paymentId     String
  invoiceId     String
  confidence    MatchConfidence
  matchCriteria Json?
  isAutoMatched Boolean            @default(false)
  status        PaymentMatchStatus @default(PENDING)
  confirmedAt   DateTime? @db.Timestamptz(6)
  confirmedBy   String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  invoice       Invoice            @relation(fields: [invoiceId], references: [id])
  payment       Payment            @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([status])
  @@map("payment_matches")
}

model Tenant {
  id                        String                     @id @default(uuid())
  lineUserId                String?                    @unique
  firstName                 String
  lastName                  String
  phone                     String
  email                     String?
  emergencyContact          String?
  emergencyPhone            String?
  createdAt                 DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @db.Timestamptz(6)
  contracts                 Contract[]                 @relation("PrimaryTenant")
  conversations             Conversation[]
  documentGenerationTargets DocumentGenerationTarget[]
  generatedDocuments        GeneratedDocument[]
  maintenanceTickets        MaintenanceTicket[]
  roomTenants               RoomTenant[]
  deliveryOrderItems        DeliveryOrderItem[]

  @@index([phone])
  @@index([email])
  @@map("tenants")
}

model RoomTenant {
  id          String     @id @default(uuid())
  roomNo      String
  tenantId    String
  role        TenantRole
  moveInDate  DateTime  @db.Date
  moveOutDate DateTime? @db.Date
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  room        Room       @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([roomNo, tenantId])
  @@index([roomNo])
  @@index([tenantId])
  @@index([role])
  @@map("room_tenants")
}

model Contract {
  id                        String                     @id @default(uuid())
  roomNo                    String
  primaryTenantId           String
  startDate                 DateTime @db.Timestamptz(6)
  endDate                   DateTime @db.Timestamptz(6)
  monthlyRent               Decimal                    @db.Decimal(10, 2)
  deposit                   Decimal?                   @db.Decimal(10, 2)
  furnitureFee              Decimal?                   @db.Decimal(10, 2)
  status                    ContractStatus             @default(ACTIVE)
  terminationDate           DateTime? @db.Timestamptz(6)
  terminationReason         String?
  createdAt                 DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @db.Timestamptz(6)
  primaryTenant             Tenant                     @relation("PrimaryTenant", fields: [primaryTenantId], references: [id])
  room                      Room                       @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  documentGenerationTargets DocumentGenerationTarget[]
  generatedDocuments        GeneratedDocument[]
  moveOut                   MoveOut?

  @@unique([roomNo, status])
  @@index([status])
  @@index([primaryTenantId])
  @@index([startDate])
  @@index([endDate])
  @@map("contracts")
}

model LineUser {
  id            String        @id @default(uuid())
  lineUserId    String        @unique
  displayName   String
  pictureUrl    String?
  statusMessage String?
  lastFetchedAt DateTime? @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  conversations Conversation?
  maintenanceState LineMaintenanceState?

  @@map("line_users")
}

model LineMaintenanceState {
  id            String   @id @default(uuid())
  lineUserId    String   @unique
  currentStep  String
  requestData  Json
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  lineUser      LineUser @relation(fields: [lineUserId], references: [lineUserId], onDelete: Cascade)

  @@map("line_maintenance_states")
}

model Conversation {
  id            String             @id @default(uuid())
  lineUserId    String             @unique
  tenantId      String?
  roomNo        String?
  lastMessageAt DateTime @db.Timestamptz(6)
  unreadCount   Int                @default(0)
  status        ConversationStatus @default(ACTIVE)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  lineUser      LineUser           @relation(fields: [lineUserId], references: [lineUserId])
  room          Room?              @relation(fields: [roomNo], references: [roomNo])
  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  messages      Message[]

  @@index([tenantId])
  @@index([roomNo])
  @@index([unreadCount])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  lineMessageId  String           @unique
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  metadata       Json?
  isRead         Boolean          @default(false)
  readAt         DateTime? @db.Timestamptz(6)
  sentAt         DateTime @db.Timestamptz(6)
  receivedAt     DateTime @default(now()) @db.Timestamptz(6)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([direction])
  @@index([sentAt])
  @@index([conversationId, sentAt])
  @@map("messages")
}

model Notification {
  id            String             @id @default(uuid())
  type          NotificationType
  roomNo        String
  tenantId      String?
  adminId       String?
  contractId    String?
  scheduledAt   DateTime @db.Timestamptz(6)
  sentAt        DateTime? @db.Timestamptz(6)
  status        NotificationStatus @default(PENDING)
  content       String
  lineMessageId String?
  errorMessage  String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([roomNo])
  @@index([tenantId])
  @@index([adminId])
  @@index([status])
  @@index([scheduledAt])
  @@index([contractId])
  @@index([roomNo, status])
  @@map("notifications")
}

model MessageTemplate {
  id        String              @id @default(uuid())
  name      String
  type      MessageTemplateType @default(CUSTOM)
  body      String
  variables String[]
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([type])
  @@map("message_templates")
}

model UploadedFile {
  id                           String                    @id @default(uuid())
  originalName                 String
  mimeType                     String
  size                         Int
  storageKey                   String                    @unique
  url                          String
  status                       UploadedFileStatus        @default(ACTIVE)
  archivedAt                   DateTime? @db.Timestamptz(6)
  uploadedBy                   String?
  createdAt                    DateTime @default(now()) @db.Timestamptz(6)
  documentGenerationJobBundles DocumentGenerationJob[]   @relation("GenerationJobBundleFile")
  templateVersions             DocumentTemplateVersion[] @relation("TemplateVersionSourceFile")
  generatedDocumentFiles       GeneratedDocumentFile[]

  @@index([mimeType])
  @@index([createdAt])
  @@index([status])
  @@map("uploaded_files")
}

model MaintenanceTicket {
  id              String                  @id @default(uuid())
  roomNo          String
  tenantId        String
  title           String
  description     String
  priority        MaintenancePriority     @default(MEDIUM)
  status          MaintenanceStatus       @default(OPEN)
  assignedStaffId String?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)
  attachments     MaintenanceAttachment[]
  comments        MaintenanceComment[]
  room            Room                    @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([roomNo])
  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_tickets")
}

model MaintenanceComment {
  id        String            @id @default(uuid())
  ticketId  String
  authorId  String
  message   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  ticket    MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("maintenance_comments")
}

model MaintenanceAttachment {
  id        String            @id @default(uuid())
  ticketId  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  ticket    MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("maintenance_attachments")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  userName   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Config {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@map("configs")
}

model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  processedAt   DateTime? @db.Timestamptz(6)
  retryCount    Int       @default(0)
  lastError     String?

  @@index([processedAt])
  @@index([aggregateType, aggregateId])
  @@index([processedAt, createdAt])
  @@index([eventType])
  @@index([retryCount])
  @@map("outbox_events")
}

model AdminUser {
  id                  String               @id @default(uuid())
  username            String               @unique
  email               String?              @unique
  displayName         String
  role                AdminRole            @default(STAFF)
  passwordHash        String
  isActive            Boolean              @default(true)
  forcePasswordChange Boolean              @default(false)
  lineUserId          String?
  // buildingId: Reserved for multi-tenant/building isolation.
  // Currently not enforced at API layer - ADMIN users can access all buildings' data.
  // TODO: Add proper relations when Building model is introduced.
  buildingId          String?
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)
  resetTokens         PasswordResetToken[]

  @@index([role])
  @@index([isActive])
  @@index([buildingId])
  @@map("admin_users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model StaffRegistrationRequest {
  id           String                  @id @default(uuid())
  username     String
  email        String?
  displayName  String
  passwordHash String
  status       StaffRegistrationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime? @db.Timestamptz(6)
  rejectReason String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  @@unique([username, status])
  @@unique([email, status])
  @@index([status])
  @@index([createdAt])
  @@map("staff_registration_requests")
}

model TenantRegistration {
  id               String                   @id @default(uuid())
  lineUserId       String                   @unique
  lineDisplayName  String?
  phone            String?
  claimedRoom      String?
  status           TenantRegistrationStatus @default(PENDING)
  registrationStep RegistrationStep?
  rejectionReason  String?
  correctionNote   String?
  resolvedRoomNo   String?
  resolvedTenantId String?
  reviewedById     String?
  reviewedAt       DateTime? @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([lineUserId])
  @@map("tenant_registrations")
}

model DocumentTemplate {
  id                 String                            @id @default(uuid())
  name               String
  type               DocumentTemplateType              @default(INVOICE)
  description        String?
  status             DocumentTemplateStatus            @default(DRAFT)
  subject            String?
  body               String
  activeVersionId    String?
  createdById        String?
  updatedById        String?
  archivedAt         DateTime? @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)
  generationJobs     DocumentGenerationJob[]
  fieldDefinitions   DocumentTemplateFieldDefinition[]
  versions           DocumentTemplateVersion[]         @relation("TemplateVersions")
  activeVersion      DocumentTemplateVersion?          @relation("ActiveTemplateVersion", fields: [activeVersionId], references: [id])
  generatedDocuments GeneratedDocument[]

  @@index([type])
  @@index([status])
  @@index([type, status])
  @@map("document_templates")
}

model DocumentTemplateVersion {
  id                 String                        @id @default(uuid())
  templateId         String
  version            Int
  label              String?
  subject            String?
  body               String
  status             DocumentTemplateVersionStatus @default(DRAFT)
  fileType           String                        @default("html")
  fileName           String?
  storageKey         String?
  checksum           String?
  sourceFileId       String?
  createdById        String?
  activatedById      String?
  activatedAt        DateTime? @db.Timestamptz(6)
  archivedAt         DateTime? @db.Timestamptz(6)
  meta               Json?
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)
  generationJobs     DocumentGenerationJob[]
  sourceFile         UploadedFile?                 @relation("TemplateVersionSourceFile", fields: [sourceFileId], references: [id])
  template           DocumentTemplate              @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeForTemplates DocumentTemplate[]            @relation("ActiveTemplateVersion")
  generatedDocuments GeneratedDocument[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@index([sourceFileId])
  @@map("document_template_versions")
}

model DocumentTemplateFieldDefinition {
  id           String                 @id @default(uuid())
  templateId   String
  key          String
  label        String
  category     DocumentFieldCategory
  valueType    DocumentFieldValueType
  path         String
  description  String?
  sampleValue  String?
  isRequired   Boolean                @default(false)
  isCollection Boolean                @default(false)
  sortOrder    Int                    @default(0)
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)
  template     DocumentTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, category, sortOrder])
  @@map("document_template_field_definitions")
}

model DocumentGenerationJob {
  id                 String                      @id @default(uuid())
  templateId         String
  templateVersionId  String
  requestedById      String?
  billingPeriodId    String?
  year               Int?
  month              Int?
  scope              DocumentSourceScope
  selection          Json?
  dryRun             Boolean                     @default(false)
  status             DocumentGenerationJobStatus @default(QUEUED)
  totalRequested     Int                         @default(0)
  successCount       Int                         @default(0)
  skippedCount       Int                         @default(0)
  failedCount        Int                         @default(0)
  errorMessage       String?
  bundleFileId       String?
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  startedAt          DateTime? @db.Timestamptz(6)
  completedAt        DateTime? @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)
  bundleFile         UploadedFile?               @relation("GenerationJobBundleFile", fields: [bundleFileId], references: [id])
  template           DocumentTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion    DocumentTemplateVersion     @relation(fields: [templateVersionId], references: [id])
  targets            DocumentGenerationTarget[]
  generatedDocuments GeneratedDocument[]

  @@index([templateId, createdAt])
  @@index([templateVersionId])
  @@index([billingPeriodId])
  @@index([status])
  @@map("document_generation_jobs")
}

model DocumentGenerationTarget {
  id                  String                         @id @default(uuid())
  jobId               String
  roomNo              String
  roomBillingId       String?
  invoiceId           String?
  contractId          String?
  tenantId            String?
  status              DocumentGenerationTargetStatus @default(PENDING)
  generatedDocumentId String?
  reason              String?
  renderSummary       Json?
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)
  contract            Contract?                      @relation(fields: [contractId], references: [id])
  invoice             Invoice?                       @relation(fields: [invoiceId], references: [id])
  job                 DocumentGenerationJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  room                Room                           @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant              Tenant?                        @relation(fields: [tenantId], references: [id])

  @@unique([jobId, roomNo])
  @@index([status])
  @@index([generatedDocumentId])
  @@map("document_generation_targets")
}

model GeneratedDocument {
  id                String                  @id @default(uuid())
  templateId        String
  templateVersionId String
  generationJobId   String?
  documentType      DocumentTemplateType
  status            GeneratedDocumentStatus @default(GENERATED)
  title             String
  subject           String?
  sourceScope       DocumentSourceScope
  roomNo            String
  billingPeriodId   String?
  roomBillingId     String?
  invoiceId         String?
  contractId        String?
  tenantId          String?
  year              Int?
  month             Int?
  documentVersion   Int                     @default(1)
  generatedById     String?
  renderContext     Json?
  validation        Json?
  generatedAt       DateTime @default(now()) @db.Timestamptz(6)
  archivedAt        DateTime? @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)
  files             GeneratedDocumentFile[]
  contract          Contract?               @relation(fields: [contractId], references: [id])
  generationJob     DocumentGenerationJob?  @relation(fields: [generationJobId], references: [id])
  invoice           Invoice?                @relation(fields: [invoiceId], references: [id])
  room              Room                    @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  template          DocumentTemplate        @relation(fields: [templateId], references: [id])
  templateVersion   DocumentTemplateVersion @relation(fields: [templateVersionId], references: [id])
  tenant            Tenant?                 @relation(fields: [tenantId], references: [id])
  deliveryOrderItems DeliveryOrderItem[]

  @@index([templateId, generatedAt])
  @@index([templateVersionId])
  @@index([roomNo, year, month])
  @@index([billingPeriodId])
  @@index([roomBillingId])
  @@index([status])
  @@map("generated_documents")
}

model GeneratedDocumentFile {
  id                  String                    @id @default(uuid())
  generatedDocumentId String
  uploadedFileId      String
  role                GeneratedDocumentFileRole
  format              String
  isPrimary           Boolean                   @default(false)
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  generatedDocument   GeneratedDocument         @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)
  uploadedFile        UploadedFile              @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([generatedDocumentId, role])
  @@index([uploadedFileId])
  @@map("generated_document_files")
}

model DeliveryOrder {
  id            String              @id @default(uuid())
  channel       DeliveryChannel     @default(LINE)
  documentType  DocumentTemplateType
  description   String?
  year          Int?
  month         Int?
  floorNumber   Int?
  scopeRoomNos  String[]
  status        DeliveryOrderStatus @default(DRAFT)
  totalCount    Int                 @default(0)
  sentCount     Int                 @default(0)
  failedCount   Int                 @default(0)
  createdBy     String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  items         DeliveryOrderItem[]

  @@index([status])
  @@index([year, month])
  @@index([createdAt])
  @@map("delivery_orders")
}

model DeliveryOrderItem {
  id                  String                @id @default(uuid())
  deliveryOrderId     String
  roomNo              String
  tenantId            String?
  generatedDocumentId String?
  invoiceId           String?
  recipientRef        String?
  status              DeliveryItemStatus    @default(PENDING)
  sentAt              DateTime? @db.Timestamptz(6)
  errorMessage        String?
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)
  deliveryOrder       DeliveryOrder         @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  room                Room                  @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant              Tenant?               @relation(fields: [tenantId], references: [id])
  generatedDocument   GeneratedDocument?    @relation(fields: [generatedDocumentId], references: [id])
  invoice             Invoice?              @relation(fields: [invoiceId], references: [id])

  @@index([deliveryOrderId])
  @@index([roomNo])
  @@index([status])
  @@map("delivery_order_items")
}

