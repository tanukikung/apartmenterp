# Customer deployment template for Docker Compose.
# The init script will create .env.customer from this file and generate secrets.

# Public app URL. Keep http://localhost:3000 for a local install.
# When deploying behind HTTPS, change this to your final domain.
APP_BASE_URL=__APP_BASE_URL__

# Port exposed on the host machine.
APP_PORT=__APP_PORT__

# Container time zone for logs, scheduled jobs, and backup timestamps.
TZ=Asia/Bangkok

# Embedded PostgreSQL configuration.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=apartment_erp

# Session and cron secrets. The init script generates strong random values.
NEXTAUTH_SECRET=__NEXTAUTH_SECRET__
CRON_SECRET=__CRON_SECRET__
INVOICE_ACCESS_SECRET=__INVOICE_ACCESS_SECRET__
FILE_ACCESS_SECRET=__FILE_ACCESS_SECRET__
SEED_OWNER_PASSWORD=__SEED_OWNER_PASSWORD__
SEED_STAFF_PASSWORD=__SEED_STAFF_PASSWORD__

# Core runtime flags.
COOKIE_SECURE=__COOKIE_SECURE__
CRON_ENABLED=true
NODE_ENV=production

# Persistent storage inside the mounted app data volume.
STORAGE_DRIVER=local
UPLOAD_DIR=/app/data/uploads
BACKUP_DIR=/app/data/backups
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=7

# Optional integrations. The customer stack includes Redis by default.
# Override REDIS_URL only if you want to use an external Redis instance instead.
REDIS_URL=redis://redis:6379
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
SENTRY_DSN=
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
