# ╔══════════════════════════════════════════════════════════════════╗
# ║     Apartment ERP — Environment Variables สำหรับ Coolify         ║
# ║                                                                  ║
# ║  วิธีใช้: คัดลอก Key + Value ทีละบรรทัด ไปกรอกใน Coolify UI    ║
# ║  (Coolify > Project > Service > Environment Variables)           ║
# ╚══════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] Database Password
# ใช้รหัสผ่านที่แข็งแรง — ตัวเลข+ตัวอักษร ไม่มีช่องว่าง
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] Redis Password
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] NextAuth Secret — สร้างด้วย: openssl rand -base64 32
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXTAUTH_SECRET=CHANGE_THIS_NEXTAUTH_SECRET

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] App URL — domain จริงที่ตั้งใน Coolify
# ตัวอย่าง: https://erp.yourdomain.com
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_BASE_URL=https://erp.yourdomain.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] OnlyOffice Secret — สร้างด้วย: openssl rand -base64 32
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ONLYOFFICE_JWT_SECRET=CHANGE_THIS_ONLYOFFICE_SECRET

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [REQUIRED] OnlyOffice URL — domain/subdomain ที่ Coolify ตั้งให้ onlyoffice service
# ตัวอย่าง: https://office.yourdomain.com
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ONLYOFFICE_DOCUMENT_SERVER_URL=https://office.yourdomain.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [OPTIONAL] Cron Secret
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CRON_SECRET=CHANGE_THIS_CRON_SECRET

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# [OPTIONAL] LINE Integration — เว้นว่างถ้าไม่ใช้
# ได้จาก LINE Developers Console: https://developers.line.biz
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
