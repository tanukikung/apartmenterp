{
  "name": "apartment-erp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "tsup src/server/worker.ts --format cjs --platform node --target node20 --out-dir dist --minify --sourcemap",
    "build:scheduler": "tsup scripts/backup-scheduler.ts --format cjs --platform node --target node20 --out-dir dist --minify --sourcemap",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t apartment-erp .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "vitest run --pool=forks",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.624.0",
    "@fontsource/sarabun": "^5.2.8",
    "@line/bot-sdk": "^9.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-color": "^3.20.2",
    "@tiptap/extension-font-family": "^3.20.2",
    "@tiptap/extension-highlight": "^3.20.2",
    "@tiptap/extension-image": "^3.20.2",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/extension-placeholder": "^3.20.2",
    "@tiptap/extension-table": "^3.20.2",
    "@tiptap/extension-table-cell": "^3.20.2",
    "@tiptap/extension-table-header": "^3.20.2",
    "@tiptap/extension-table-row": "^3.20.2",
    "@tiptap/extension-text-align": "^3.20.2",
    "@tiptap/extension-text-style": "^3.20.2",
    "@tiptap/extension-underline": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.4.3",
    "lucide-react": "^0.577.0",
    "next": "14.2.21",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "redis": "^4.6.13",
    "tailwind-merge": "^2.5.4",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.14",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
