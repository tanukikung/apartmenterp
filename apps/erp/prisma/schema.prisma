// ── Document Templates ──────────────────────────────────────────────────────
// User-editable templates for invoices, contracts, receipts, and notices.

enum DocumentTemplateType {
  INVOICE
  PAYMENT_NOTICE
  CONTRACT
  RECEIPT
  GENERAL_NOTICE
  NOTICE
  OTHER
}

model DocumentTemplate {
  id              String                 @id @default(uuid())
  name            String
  type            DocumentTemplateType   @default(INVOICE)
  description     String?
  status          DocumentTemplateStatus @default(DRAFT)
  subject         String?
  body            String                 @db.Text
  activeVersionId String?
  createdById     String?
  updatedById     String?
  archivedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  activeVersion      DocumentTemplateVersion?          @relation("ActiveTemplateVersion", fields: [activeVersionId], references: [id])
  versions           DocumentTemplateVersion[]         @relation("TemplateVersions")
  fieldDefinitions   DocumentTemplateFieldDefinition[]
  generationJobs     DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]

  @@index([type])
  @@index([status])
  @@index([type, status])
  @@map("document_templates")
}

model DocumentTemplateVersion {
  id            String                        @id @default(uuid())
  templateId    String
  version       Int
  label         String?
  subject       String?
  body          String                        @db.Text
  status        DocumentTemplateVersionStatus @default(DRAFT)
  fileType      String                        @default("html")
  fileName      String?
  storageKey    String?
  checksum      String?
  sourceFileId  String?
  createdById   String?
  activatedById String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  meta          Json?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  template           DocumentTemplate        @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeForTemplates DocumentTemplate[]      @relation("ActiveTemplateVersion")
  sourceFile         UploadedFile?           @relation("TemplateVersionSourceFile", fields: [sourceFileId], references: [id])
  generationJobs     DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@index([sourceFileId])
  @@map("document_template_versions")
}

model DocumentTemplateFieldDefinition {
  id           String                 @id @default(uuid())
  templateId   String
  key          String
  label        String
  category     DocumentFieldCategory
  valueType    DocumentFieldValueType
  path         String
  description  String?
  sampleValue  String?
  isRequired   Boolean                @default(false)
  isCollection Boolean                @default(false)
  sortOrder    Int                    @default(0)
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, category, sortOrder])
  @@map("document_template_field_definitions")
}

model DocumentGenerationJob {
  id                String                      @id @default(uuid())
  templateId        String
  templateVersionId String
  requestedById     String?
  billingCycleId    String?
  year              Int?
  month             Int?
  scope             DocumentSourceScope
  selection         Json?
  dryRun            Boolean                     @default(false)
  status            DocumentGenerationJobStatus @default(QUEUED)
  totalRequested    Int                         @default(0)
  successCount      Int                         @default(0)
  skippedCount      Int                         @default(0)
  failedCount       Int                         @default(0)
  errorMessage      String?
  bundleFileId      String?
  createdAt         DateTime                    @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  updatedAt         DateTime                    @updatedAt

  template           DocumentTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion    DocumentTemplateVersion    @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  billingCycle       BillingCycle?              @relation(fields: [billingCycleId], references: [id])
  bundleFile         UploadedFile?              @relation("GenerationJobBundleFile", fields: [bundleFileId], references: [id])
  targets            DocumentGenerationTarget[]
  generatedDocuments GeneratedDocument[]

  @@index([templateId, createdAt])
  @@index([templateVersionId])
  @@index([billingCycleId])
  @@index([status])
  @@map("document_generation_jobs")
}

model DocumentGenerationTarget {
  id                  String                         @id @default(uuid())
  jobId               String
  roomId              String
  billingRecordId     String?
  invoiceId           String?
  contractId          String?
  tenantId            String?
  status              DocumentGenerationTargetStatus @default(PENDING)
  generatedDocumentId String?
  reason              String?
  renderSummary       Json?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  job           DocumentGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  room          Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  billingRecord BillingRecord?        @relation(fields: [billingRecordId], references: [id])
  invoice       Invoice?              @relation(fields: [invoiceId], references: [id])
  contract      Contract?             @relation(fields: [contractId], references: [id])
  tenant        Tenant?               @relation(fields: [tenantId], references: [id])

  @@unique([jobId, roomId])
  @@index([status])
  @@index([generatedDocumentId])
  @@map("document_generation_targets")
}

model GeneratedDocument {
  id                String                  @id @default(uuid())
  templateId        String
  templateVersionId String
  generationJobId   String?
  documentType      DocumentTemplateType
  status            GeneratedDocumentStatus @default(GENERATED)
  title             String
  subject           String?
  sourceScope       DocumentSourceScope
  roomId            String
  buildingId        String?
  billingCycleId    String?
  billingRecordId   String?
  invoiceId         String?
  contractId        String?
  tenantId          String?
  year              Int?
  month             Int?
  documentVersion   Int                     @default(1)
  generatedById     String?
  renderContext     Json?
  validation        Json?
  generatedAt       DateTime                @default(now())
  archivedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  template        DocumentTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion DocumentTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  generationJob   DocumentGenerationJob?  @relation(fields: [generationJobId], references: [id])
  room            Room                    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  building        Building?               @relation(fields: [buildingId], references: [id])
  billingCycle    BillingCycle?           @relation(fields: [billingCycleId], references: [id])
  billingRecord   BillingRecord?          @relation(fields: [billingRecordId], references: [id])
  invoice         Invoice?                @relation(fields: [invoiceId], references: [id])
  contract        Contract?               @relation(fields: [contractId], references: [id])
  tenant          Tenant?                 @relation(fields: [tenantId], references: [id])
  files           GeneratedDocumentFile[]

  @@index([templateId, generatedAt])
  @@index([templateVersionId])
  @@index([roomId, year, month])
  @@index([billingCycleId])
  @@index([billingRecordId])
  @@index([status])
  @@map("generated_documents")
}

model GeneratedDocumentFile {
  id                  String                    @id @default(uuid())
  generatedDocumentId String
  uploadedFileId      String
  role                GeneratedDocumentFileRole
  format              String
  isPrimary           Boolean                   @default(false)
  createdAt           DateTime                  @default(now())

  generatedDocument GeneratedDocument @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)
  uploadedFile      UploadedFile      @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([generatedDocumentId, role])
  @@index([uploadedFileId])
  @@map("generated_document_files")
}

// ── Message Templates ───────────────────────────────────────────────────────
// User-editable LINE message templates for invoice sends, reminders, notices.

enum MessageTemplateType {
  INVOICE_SEND
  PAYMENT_REMINDER
  OVERDUE_NOTICE
  CUSTOM
}

model MessageTemplate {
  id        String              @id @default(uuid())
  name      String
  type      MessageTemplateType @default(CUSTOM)
  body      String              @db.Text
  variables String[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([type])
  @@map("message_templates")
}

// ── Tenant LINE Registration Requests ──────────────────────────────────────
// Created when a tenant registers via LINE bot. Admin reviews and approves /
// rejects / requests correction. On approval a Tenant record is linked.
model TenantRegistration {
  id               String                   @id @default(uuid())
  lineUserId       String                   @unique
  lineDisplayName  String?
  phone            String?
  claimedRoom      String? // room number as self-reported by tenant
  status           TenantRegistrationStatus @default(PENDING)
  rejectionReason  String?
  correctionNote   String? // note sent back when requesting correction
  resolvedRoomId   String? // FK resolved on approval
  resolvedTenantId String? // Tenant.id linked after approval
  reviewedById     String? // AdminUser.id
  reviewedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([status])
  @@index([lineUserId])
  @@map("tenant_registrations")
}
