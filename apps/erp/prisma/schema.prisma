// Apartment ERP - Prisma Schema
// PostgreSQL Database Schema
// ─────────────────────────────────────────────────────────────────
// Revision notes:
//   • All existing tables/enums kept intact for backward compatibility
//   • New tables added: bank_accounts, billing_cycles,
//     billing_policy_snapshots, billing_import_batches,
//     billing_import_rows, invoice_deliveries
//   • Extended tables: rooms, contracts, billing_records,
//     billing_items, payment_transactions, uploaded_files,
//     buildings (back-ref only)
//   • New enum values appended to RoomStatus (SELF_USE, UNAVAILABLE)
//   • All new columns on existing tables are nullable or have defaults
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS — EXISTING (unchanged values; only RoomStatus extended)
// ============================================================================

enum RoomStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  SELF_USE // added — room used by owner/staff, not rented
  UNAVAILABLE // added — physically unusable / under renovation
}

enum TenantRole {
  PRIMARY
  SECONDARY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum BillingStatus {
  DRAFT
  LOCKED
  INVOICED
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  SENT
  VIEWED
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  MATCHED
  CONFIRMED
  REJECTED
}

enum PaymentTransactionStatus {
  PENDING
  AUTO_MATCHED
  NEED_REVIEW
  CONFIRMED
  REJECTED
}

enum PaymentMatchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum MatchConfidence {
  HIGH
  MEDIUM
  LOW
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationType {
  INVOICE_REMINDER
  PAYMENT_REMINDER
  NOTICE
  CUSTOM
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  DONE
  CLOSED
}

enum AdminRole {
  ADMIN
  STAFF
}

enum StaffRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TenantRegistrationStatus {
  PENDING
  CORRECTION_REQUESTED
  APPROVED
  REJECTED
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentTemplateVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentFieldCategory {
  ROOM
  TENANT
  CONTRACT
  BILLING
  BILLING_ITEM
  PAYMENT
  APARTMENT
  SYSTEM
  COMPUTED
}

enum DocumentFieldValueType {
  STRING
  NUMBER
  DATE
  BOOLEAN
  CURRENCY
  ARRAY
  OBJECT
  HTML
}

enum DocumentGenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum DocumentGenerationTargetStatus {
  PENDING
  SUCCESS
  SKIPPED
  FAILED
}

enum DocumentSourceScope {
  SINGLE_ROOM
  SELECTED_ROOMS
  FLOOR
  ELIGIBLE_FOR_MONTH
  OCCUPIED_ROOMS
  ROOMS_WITH_BILLING
}

enum GeneratedDocumentStatus {
  GENERATED
  EXPORTED
  SENT
  ARCHIVED
  FAILED
}

enum GeneratedDocumentFileRole {
  SOURCE_HTML
  PDF
  DOCX
  ZIP_BUNDLE
  PREVIEW
}

// ============================================================================
// ENUMS — NEW
// ============================================================================

/// Monthly billing cycle lifecycle
enum BillingCycleStatus {
  OPEN // cycle created, not yet imported
  IMPORTED // import batch committed to billing_records
  LOCKED // billing_records locked, invoices may be generated
  INVOICED // all invoices generated
  CLOSED // period closed, read-only
}

/// Import batch processing lifecycle
enum BillingImportBatchStatus {
  UPLOADED // file uploaded, not yet parsed/validated
  VALIDATED // rows parsed and validated, not yet committed
  IMPORTED // rows converted to billing_records
  FAILED // parsing or commit failed
}

/// Per-row validation result in staging table
enum BillingImportRowStatus {
  VALID // row passed all validation rules
  WARNING // row has non-blocking issues (review recommended)
  ERROR // row failed validation, must not be imported
}

/// Room intended usage classification
enum RoomUsageType {
  RENTAL // standard rental room
  SELF_USE // owner/staff occupied
  RESERVED // held for future use
  STORAGE // storage / non-habitable
}

/// Whether a room participates in monthly billing
enum RoomBillingStatus {
  BILLABLE // generate billing_record each cycle
  NON_BILLABLE // skip billing (vacant, self-use, etc.)
  SUSPENDED // temporarily excluded from billing
}

/// Source that created a billing line item
enum BillingItemSourceType {
  IMPORT // originated from Excel import row
  CONTRACT // derived from contract terms
  MANUAL // entered manually by staff
  SYSTEM // auto-generated by system rule
}

/// Invoice delivery channel
enum InvoiceDeliveryChannel {
  LINE // LINE Messaging API
  PDF // PDF file (print / email)
  PRINT // physical printout tracked
}

/// Delivery attempt status
enum InvoiceDeliveryStatus {
  PENDING // queued but not yet sent
  SENT // successfully dispatched
  FAILED // dispatch failed
  VIEWED // recipient confirmed viewing
}

/// Payment matching result type
enum PaymentMatchType {
  FULL // payment covers invoice exactly
  PARTIAL // payment < invoice amount
  OVERPAY // payment > invoice amount
  UNDERPAY // synonym for PARTIAL (kept for import compatibility)
}

// ============================================================================
// BUILDING & LOCATION
// ============================================================================

model Building {
  id          String   @id @default(uuid())
  name        String
  address     String
  totalFloors Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors             Floor[]
  billingCycles      BillingCycle[] // new back-reference
  generatedDocuments GeneratedDocument[]

  @@map("buildings")
}

model Floor {
  id          String   @id @default(uuid())
  buildingId  String
  floorNumber Int
  createdAt   DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms    Room[]

  @@unique([buildingId, floorNumber])
  @@map("floors")
}

model Room {
  id           String     @id @default(uuid())
  floorId      String
  roomNumber   String
  status       RoomStatus @default(VACANT)
  maxResidents Int        @default(2)

  // ── new additive fields ──────────────────────────────────────────
  usageType            RoomUsageType     @default(RENTAL)
  billingStatus        RoomBillingStatus @default(BILLABLE)
  defaultBankAccountId String? // FK → bank_accounts
  defaultFurnitureFee  Decimal?          @db.Decimal(10, 2)
  sortOrder            Int? // display order within floor
  note                 String?
  isActive             Boolean           @default(true)
  // ────────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor                     Floor                      @relation(fields: [floorId], references: [id], onDelete: Cascade)
  roomTenants               RoomTenant[]
  contracts                 Contract[]
  billingRecords            BillingRecord[]
  invoices                  Invoice[]
  conversations             Conversation[]
  maintenanceTickets        MaintenanceTicket[]
  importRows                BillingImportRow[]         @relation("ImportRowMatchedRoom") // new back-ref
  defaultBankAccount        BankAccount?               @relation("RoomDefaultBankAccount", fields: [defaultBankAccountId], references: [id])
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([floorId, roomNumber])
  @@index([status])
  @@index([usageType])
  @@index([billingStatus])
  @@index([isActive])
  @@map("rooms")
}

// ============================================================================
// TENANT MANAGEMENT  (unchanged)
// ============================================================================

model Tenant {
  id               String   @id @default(uuid())
  lineUserId       String?
  firstName        String
  lastName         String
  phone            String
  email            String?
  emergencyContact String?
  emergencyPhone   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  roomTenants               RoomTenant[]
  contracts                 Contract[]                 @relation("PrimaryTenant")
  conversations             Conversation[]
  maintenanceTickets        MaintenanceTicket[]
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([lineUserId])
  @@index([phone])
  @@index([email])
  @@map("tenants")
}

model RoomTenant {
  id          String     @id @default(uuid())
  roomId      String
  tenantId    String
  role        TenantRole
  moveInDate  DateTime
  moveOutDate DateTime?
  createdAt   DateTime   @default(now())

  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // App-level rules enforced in service layer:
  //   • max 2 active occupants per room  (maxResidents guard)
  //   • max 1 active PRIMARY per room    (service-layer check)
  @@unique([roomId, tenantId])
  @@index([roomId])
  @@index([tenantId])
  @@index([role])
  @@map("room_tenants")
}

// ============================================================================
// CONTRACT MANAGEMENT
// ============================================================================

model Contract {
  id                String         @id @default(uuid())
  roomId            String
  primaryTenantId   String
  startDate         DateTime
  endDate           DateTime
  monthlyRent       Decimal        @db.Decimal(10, 2)
  deposit           Decimal?       @db.Decimal(10, 2)
  furnitureFee      Decimal?       @db.Decimal(10, 2) // new — snapshot for billing
  status            ContractStatus @default(ACTIVE)
  terminationDate   DateTime?
  terminationReason String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  room                      Room                       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  primaryTenant             Tenant                     @relation("PrimaryTenant", fields: [primaryTenantId], references: [id], onDelete: Restrict)
  billingRecords            BillingRecord[] // new back-ref
  importRows                BillingImportRow[]         @relation("ImportRowMatchedContract") // new back-ref
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([roomId, status]) // one active contract per room
  @@index([status])
  @@index([primaryTenantId])
  @@index([startDate])
  @@index([endDate])
  @@map("contracts")
}

// ============================================================================
// BILLING ITEM TYPES  (unchanged)
// ============================================================================

model BillingItemType {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String?
  isRecurring   Boolean  @default(true)
  defaultAmount Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  billingItems BillingItem[]

  @@map("billing_item_types")
}

// ============================================================================
// BILLING RECORD  (extended)
// ============================================================================

model BillingRecord {
  id         String        @id @default(uuid())
  roomId     String
  year       Int
  month      Int
  billingDay Int
  dueDay     Int
  overdueDay Int
  status     BillingStatus @default(DRAFT)
  lockedAt   DateTime?
  lockedBy   String?
  subtotal   Decimal       @default(0) @db.Decimal(12, 2)
  isPaid     Boolean       @default(false)

  // ── new additive fields ──────────────────────────────────────────
  billingCycleId   String? // FK → billing_cycles
  contractId       String? // FK → contracts
  policySnapshotId String? // FK → billing_policy_snapshots
  importBatchId    String? // FK → billing_import_batches

  // importRowId: denormalised reference for quick lookup.
  // The enforced FK lives on billing_import_rows.importedBillingRecordId.
  // Not declared as a Prisma @relation here to avoid circular FK.
  importRowId String?

  roomStatusSnapshot      String? // RoomStatus value at time of billing
  tenantSnapshotJson      Json? // {name, phone, lineUserId, ...} at billing time
  bankAccountSnapshotJson Json? // {code, accountNumber, ...} at billing time
  total                   Decimal? @db.Decimal(12, 2) // subtotal + fees if applicable
  remark                  String?
  // ────────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room                      Room                       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  items                     BillingItem[]
  invoices                  Invoice[]
  billingCycle              BillingCycle?              @relation(fields: [billingCycleId], references: [id])
  contract                  Contract?                  @relation(fields: [contractId], references: [id])
  policySnapshot            BillingPolicySnapshot?     @relation(fields: [policySnapshotId], references: [id])
  importBatch               BillingImportBatch?        @relation("BatchBillingRecords", fields: [importBatchId], references: [id])
  // Reverse side of billing_import_rows.importedBillingRecord (FK lives there)
  importRows                BillingImportRow[]         @relation("ImportRowBillingRecord")
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([roomId, year, month])
  @@index([roomId])
  @@index([year, month])
  @@index([status])
  @@index([billingCycleId])
  @@index([contractId])
  @@index([policySnapshotId])
  @@index([importBatchId])
  @@map("billing_records")
}

// ============================================================================
// BILLING ITEM  (extended)
// ============================================================================

model BillingItem {
  id              String  @id @default(uuid())
  billingRecordId String
  itemTypeId      String
  description     String?
  quantity        Decimal @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal @db.Decimal(10, 2)
  amount          Decimal @db.Decimal(12, 2)
  isEditable      Boolean @default(true)

  // ── new additive fields ──────────────────────────────────────────
  code         String? // mirrors billing_item_types.code, denorm for fast read
  sortOrder    Int?
  sourceType   BillingItemSourceType?
  sourceRef    String? // free-form ref (importRowId, contractId, etc.)
  snapshotJson Json? // meter readings, unit prices at billing time
  // ────────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billingRecord BillingRecord   @relation(fields: [billingRecordId], references: [id], onDelete: Cascade)
  itemType      BillingItemType @relation(fields: [itemTypeId], references: [id])

  @@index([billingRecordId])
  @@index([itemTypeId])
  @@index([sourceType])
  @@map("billing_items")
}

// ============================================================================
// BANK ACCOUNTS  (new)
// ============================================================================

model BankAccount {
  id            String   @id @default(cuid())
  code          String   @unique // e.g. "SCB_MAIN", "KTB_RENT"
  bankName      String
  accountName   String
  accountNumber String
  promptpayId   String?
  qrPayload     String? // base64 / URL for PromptPay QR
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rooms               Room[]                  @relation("RoomDefaultBankAccount")
  policySnapshots     BillingPolicySnapshot[] @relation("PolicySnapshotBankAccount")
  paymentTransactions PaymentTransaction[]    @relation("TransactionBankAccount")

  @@index([isDefault])
  @@index([isActive])
  @@map("bank_accounts")
}

// ============================================================================
// BILLING CYCLE  (new)
// One row = one building × one calendar month
// ============================================================================

model BillingCycle {
  id              String             @id @default(cuid())
  buildingId      String
  year            Int
  month           Int // 1–12
  billingDate     DateTime // date invoices are issued
  dueDate         DateTime // payment due date
  overdueDate     DateTime // date after which invoices become overdue
  status          BillingCycleStatus @default(OPEN)
  formulaVersion  String? // tracks Excel template formula version
  templateVersion String? // tracks billing_import sheet version
  createdBy       String? // adminUser.id
  lockedAt        DateTime?
  lockedBy        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  building               Building                @relation(fields: [buildingId], references: [id])
  policySnapshots        BillingPolicySnapshot[]
  importBatches          BillingImportBatch[]
  billingRecords         BillingRecord[]
  generatedDocuments     GeneratedDocument[]
  documentGenerationJobs DocumentGenerationJob[]

  @@unique([buildingId, year, month])
  @@index([buildingId])
  @@index([status])
  @@index([year, month])
  @@map("billing_cycles")
}

// ============================================================================
// BILLING POLICY SNAPSHOT  (new)
// Immutable per-cycle pricing snapshot — old months never change
// ============================================================================

model BillingPolicySnapshot {
  id                 String   @id @default(cuid())
  billingCycleId     String
  waterUnitPrice     Decimal  @db.Decimal(10, 2)
  waterServiceFee    Decimal  @db.Decimal(10, 2)
  waterMinCharge     Decimal  @db.Decimal(10, 2)
  electricUnitPrice  Decimal  @db.Decimal(10, 2)
  electricServiceFee Decimal  @db.Decimal(10, 2)
  electricMinCharge  Decimal  @db.Decimal(10, 2)
  defaultDueDay      Int? // day-of-month for payment due
  defaultOverdueDay  Int? // day-of-month for overdue threshold
  bankAccountId      String? // default payment destination for this cycle
  rawConfigJson      Json? // full config_month sheet snapshot for audit
  createdAt          DateTime @default(now())

  billingCycle   BillingCycle    @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount?    @relation("PolicySnapshotBankAccount", fields: [bankAccountId], references: [id])
  billingRecords BillingRecord[]

  @@index([billingCycleId])
  @@index([bankAccountId])
  @@map("billing_policy_snapshots")
}

// ============================================================================
// BILLING IMPORT BATCH  (new)
// One per uploaded Excel file / import attempt for a cycle
// ============================================================================

model BillingImportBatch {
  id              String                   @id @default(cuid())
  billingCycleId  String
  uploadedFileId  String? // FK → uploaded_files (optional)
  sourceFilename  String // original filename for audit
  templateVersion String?
  status          BillingImportBatchStatus @default(UPLOADED)
  totalRows       Int                      @default(0)
  validRows       Int                      @default(0)
  invalidRows     Int                      @default(0)
  importedBy      String? // adminUser.id
  importedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  billingCycle   BillingCycle       @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)
  uploadedFile   UploadedFile?      @relation("FileImportBatches", fields: [uploadedFileId], references: [id])
  importRows     BillingImportRow[]
  billingRecords BillingRecord[]    @relation("BatchBillingRecords")

  @@index([billingCycleId])
  @@index([status])
  @@map("billing_import_batches")
}

// ============================================================================
// BILLING IMPORT ROW  (new)
// Staging table — parsed rows from billing_import sheet before commit
// ============================================================================

model BillingImportRow {
  id          String  @id @default(cuid())
  batchId     String
  rowNo       Int // row sequence within this batch
  sourceSheet String? // sheet name in workbook (e.g. "billing_import")
  sourceRow   Int? // original Excel row number for traceability

  // ── Room identification ──────────────────────────────────────────
  roomNumber String
  floorNo    Int?
  tenantName String? // as written in Excel (denorm, for audit)

  // ── Rent ────────────────────────────────────────────────────────
  rentAmount Decimal? @db.Decimal(12, 2)

  // ── Water ───────────────────────────────────────────────────────
  waterPrev       Decimal? @db.Decimal(12, 2) // previous meter reading
  waterCurr       Decimal? @db.Decimal(12, 2) // current meter reading
  waterUnits      Decimal? @db.Decimal(12, 2) // units consumed
  waterUnitPrice  Decimal? @db.Decimal(10, 2)
  waterServiceFee Decimal? @db.Decimal(10, 2)
  waterMinCharge  Decimal? @db.Decimal(10, 2)
  waterAmount     Decimal? @db.Decimal(12, 2) // computed total

  // ── Electric ────────────────────────────────────────────────────
  electricPrev       Decimal? @db.Decimal(12, 2)
  electricCurr       Decimal? @db.Decimal(12, 2)
  electricUnits      Decimal? @db.Decimal(12, 2)
  electricUnitPrice  Decimal? @db.Decimal(10, 2)
  electricServiceFee Decimal? @db.Decimal(10, 2)
  electricMinCharge  Decimal? @db.Decimal(10, 2)
  electricAmount     Decimal? @db.Decimal(12, 2)

  // ── Other charges ───────────────────────────────────────────────
  furnitureAmount Decimal? @db.Decimal(12, 2)
  otherAmount     Decimal? @db.Decimal(12, 2)
  totalAmount     Decimal? @db.Decimal(12, 2)

  // ── Metadata ────────────────────────────────────────────────────
  bankAccountCode String? // matches bank_accounts.code
  note            String?
  parsedJson      Json? // raw parsed row for full traceability

  // ── Validation ──────────────────────────────────────────────────
  validationStatus     BillingImportRowStatus @default(VALID)
  validationErrorsJson Json? // [{field, message, code}]

  // ── Matching results ────────────────────────────────────────────
  matchedRoomId     String? // resolved Room.id
  matchedContractId String? // resolved Contract.id

  // ── Post-import link ────────────────────────────────────────────
  // FK lives HERE (many rows can map to the same billing record).
  // BillingRecord.importRows is the back-ref.
  importedBillingRecordId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch                 BillingImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedRoom           Room?              @relation("ImportRowMatchedRoom", fields: [matchedRoomId], references: [id])
  matchedContract       Contract?          @relation("ImportRowMatchedContract", fields: [matchedContractId], references: [id])
  importedBillingRecord BillingRecord?     @relation("ImportRowBillingRecord", fields: [importedBillingRecordId], references: [id])

  @@index([batchId, validationStatus])
  @@index([roomNumber])
  @@index([matchedRoomId])
  @@index([matchedContractId])
  @@map("billing_import_rows")
}

// ============================================================================
// INVOICE  (unchanged — back-ref for deliveries added)
// ============================================================================

model Invoice {
  id              String        @id @default(uuid())
  roomId          String
  billingRecordId String
  year            Int
  month           Int
  version         Int           @default(1)
  status          InvoiceStatus @default(DRAFT)
  subtotal        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  dueDate         DateTime
  issuedAt        DateTime?
  sentAt          DateTime?
  sentBy          String?
  viewedAt        DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  room                      Room                       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  billingRecord             BillingRecord              @relation(fields: [billingRecordId], references: [id])
  versions                  InvoiceVersion[]
  changes                   InvoiceChange[]
  paymentMatches            PaymentMatch[]
  paymentTransactions       PaymentTransaction[]       @relation("InvoicePaymentTransactions")
  deliveries                InvoiceDelivery[] // new back-ref
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([roomId, year, month, version])
  @@index([roomId])
  @@index([billingRecordId])
  @@index([status])
  @@index([year, month])
  @@index([dueDate])
  @@index([roomId, createdAt(sort: Desc)])
  @@map("invoices")
}

model InvoiceVersion {
  id              String   @id @default(uuid())
  invoiceId       String
  version         Int
  billingRecordId String
  subtotal        Decimal  @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  changeNote      String?
  createdAt       DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, version])
  @@index([invoiceId])
  @@map("invoice_versions")
}

model InvoiceChange {
  id                String   @id @default(uuid())
  invoiceId         String
  previousInvoiceId String?
  billingItemId     String?
  fieldChanged      String
  oldValue          String
  newValue          String
  createdAt         DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_changes")
}

// ============================================================================
// INVOICE DELIVERY  (new)
// Per-channel delivery tracking — replaces scattered sentAt/sentBy fields
// ============================================================================

model InvoiceDelivery {
  id           String                 @id @default(cuid())
  invoiceId    String
  channel      InvoiceDeliveryChannel
  status       InvoiceDeliveryStatus  @default(PENDING)
  recipientRef String? // LINE userId, email address, etc.
  sentAt       DateTime?
  viewedAt     DateTime?
  errorMessage String?
  createdBy    String? // adminUser.id
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([channel, status])
  @@map("invoice_deliveries")
}

// ============================================================================
// PAYMENT  (unchanged)
// ============================================================================

model Payment {
  id               String        @id @default(uuid())
  amount           Decimal       @db.Decimal(12, 2)
  paidAt           DateTime
  description      String?
  reference        String?
  sourceFile       String
  status           PaymentStatus @default(PENDING)
  matchedInvoiceId String?
  matchedAt        DateTime?
  confirmedAt      DateTime?
  confirmedBy      String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  matches PaymentMatch[]

  @@index([status])
  @@index([paidAt])
  @@index([amount])
  @@map("payments")
}

model PaymentTransaction {
  id              String                   @id @default(uuid())
  amount          Decimal                  @db.Decimal(12, 2)
  transactionDate DateTime
  description     String?
  reference       String?
  sourceFile      String
  status          PaymentTransactionStatus @default(PENDING)
  confidenceScore Decimal?                 @db.Decimal(3, 2)
  invoiceId       String?
  matchedAt       DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectReason    String?

  // ── new additive fields ──────────────────────────────────────────
  bankAccountId String? // FK → bank_accounts
  matchedAmount Decimal?          @db.Decimal(12, 2) // actual matched amount
  matchType     PaymentMatchType? // FULL / PARTIAL / OVERPAY / UNDERPAY
  // ────────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice     Invoice?     @relation("InvoicePaymentTransactions", fields: [invoiceId], references: [id])
  bankAccount BankAccount? @relation("TransactionBankAccount", fields: [bankAccountId], references: [id])

  @@index([status])
  @@index([transactionDate])
  @@index([amount])
  @@index([reference])
  @@index([bankAccountId])
  @@map("payment_transactions")
}

model PaymentMatch {
  id            String             @id @default(uuid())
  paymentId     String
  invoiceId     String
  confidence    MatchConfidence
  matchCriteria Json?
  isAutoMatched Boolean            @default(false)
  status        PaymentMatchStatus @default(PENDING)
  confirmedAt   DateTime?
  confirmedBy   String?
  createdAt     DateTime           @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([status])
  @@map("payment_matches")
}

// ============================================================================
// MESSAGING  (unchanged)
// ============================================================================

model LineUser {
  id            String    @id @default(uuid())
  lineUserId    String    @unique
  displayName   String
  pictureUrl    String?
  statusMessage String?
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]

  @@map("line_users")
}

model Conversation {
  id            String             @id @default(uuid())
  lineUserId    String
  tenantId      String?
  roomId        String?
  lastMessageAt DateTime
  unreadCount   Int                @default(0)
  status        ConversationStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  lineUser LineUser  @relation(fields: [lineUserId], references: [lineUserId])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  messages Message[]

  @@unique([lineUserId])
  @@index([tenantId])
  @@index([roomId])
  @@index([unreadCount])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  lineMessageId  String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  metadata       Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  sentAt         DateTime
  receivedAt     DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([lineMessageId])
  @@index([conversationId])
  @@index([direction])
  @@index([sentAt])
  @@index([conversationId, sentAt])
  @@map("messages")
}

model Notification {
  id            String             @id @default(uuid())
  type          NotificationType
  roomId        String
  tenantId      String
  scheduledAt   DateTime
  sentAt        DateTime?
  status        NotificationStatus @default(PENDING)
  content       String
  lineMessageId String?
  errorMessage  String?
  createdAt     DateTime           @default(now())

  @@index([roomId])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

// ============================================================================
// FILES  (extended — back-ref for import batches)
// ============================================================================

model UploadedFile {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  size         Int
  storageKey   String   @unique
  url          String
  uploadedBy   String?
  createdAt    DateTime @default(now())

  importBatches                BillingImportBatch[]      @relation("FileImportBatches") // new back-ref
  templateVersions             DocumentTemplateVersion[] @relation("TemplateVersionSourceFile")
  generatedDocumentFiles       GeneratedDocumentFile[]
  documentGenerationJobBundles DocumentGenerationJob[]   @relation("GenerationJobBundleFile")

  @@index([createdAt])
  @@map("uploaded_files")
}

