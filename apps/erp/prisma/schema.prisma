// Apartment ERP - Prisma Schema
// PostgreSQL Database Schema
// Excel-aligned billing schema redesign
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum RoomStatus {
  ACTIVE
  INACTIVE
}

enum TenantRole {
  PRIMARY
  SECONDARY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum MeterMode {
  NORMAL
  MANUAL
}

enum ServiceFeeMode {
  NONE
  FLAT_ROOM
  PER_UNIT
  MANUAL_FEE
}

enum BillingPeriodStatus {
  OPEN
  LOCKED
  CLOSED
}

enum RoomBillingStatus {
  DRAFT
  LOCKED
  INVOICED
}

enum ImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum InvoiceStatus {
  GENERATED
  SENT
  VIEWED
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  MATCHED
  CONFIRMED
  REJECTED
}

enum PaymentTransactionStatus {
  PENDING
  AUTO_MATCHED
  NEED_REVIEW
  CONFIRMED
  REJECTED
}

enum PaymentMatchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum MatchConfidence {
  HIGH
  MEDIUM
  LOW
}

enum PaymentMatchType {
  FULL
  PARTIAL
  OVERPAY
  UNDERPAY
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationType {
  INVOICE_REMINDER
  PAYMENT_REMINDER
  NOTICE
  CUSTOM
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  DONE
  CLOSED
}

enum AdminRole {
  ADMIN
  STAFF
}

enum StaffRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TenantRegistrationStatus {
  PENDING
  CORRECTION_REQUESTED
  APPROVED
  REJECTED
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentTemplateVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentFieldCategory {
  ROOM
  TENANT
  CONTRACT
  BILLING
  BILLING_ITEM
  PAYMENT
  APARTMENT
  SYSTEM
  COMPUTED
}

enum DocumentFieldValueType {
  STRING
  NUMBER
  DATE
  BOOLEAN
  CURRENCY
  ARRAY
  OBJECT
  HTML
}

enum DocumentGenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum DocumentGenerationTargetStatus {
  PENDING
  SUCCESS
  SKIPPED
  FAILED
}

enum DocumentSourceScope {
  SINGLE_ROOM
  SELECTED_ROOMS
  FLOOR
  ELIGIBLE_FOR_MONTH
  OCCUPIED_ROOMS
  ROOMS_WITH_BILLING
}

enum GeneratedDocumentStatus {
  GENERATED
  EXPORTED
  SENT
  ARCHIVED
  FAILED
}

enum GeneratedDocumentFileRole {
  SOURCE_HTML
  PDF
  DOCX
  ZIP_BUNDLE
  PREVIEW
}

enum InvoiceDeliveryChannel {
  LINE
  PDF
  PRINT
}

enum InvoiceDeliveryStatus {
  PENDING
  SENT
  FAILED
  VIEWED
}

enum MessageTemplateType {
  INVOICE_SEND
  PAYMENT_REMINDER
  OVERDUE_NOTICE
  CUSTOM
}

enum DocumentTemplateType {
  INVOICE
  PAYMENT_NOTICE
  CONTRACT
  RECEIPT
  GENERAL_NOTICE
  NOTICE
  OTHER
}

// ============================================================================
// BILLING CONFIGURATION — matches Excel ACCOUNTS sheet
// ============================================================================

model BankAccount {
  id            String  @id  // e.g. "ACC_F1"
  name          String
  bankName      String
  bankAccountNo String
  promptpay     String?
  active        Boolean @default(true)

  rooms               Room[]        @relation("RoomDefaultAccount")
  paymentTransactions PaymentTransaction[] @relation("TransactionBankAccount")

  @@map("bank_accounts")
}

// ============================================================================
// BILLING RULES — matches Excel RULES sheet
// ============================================================================

model BillingRule {
  code                  String         @id  // e.g. "STANDARD"
  descriptionTh         String
  waterEnabled          Boolean
  waterUnitPrice        Decimal        @db.Decimal(10, 2)
  waterMinCharge        Decimal        @db.Decimal(10, 2)
  waterServiceFeeMode   ServiceFeeMode
  waterServiceFeeAmount Decimal        @db.Decimal(10, 2)
  electricEnabled       Boolean
  electricUnitPrice     Decimal        @db.Decimal(10, 2)
  electricMinCharge     Decimal        @db.Decimal(10, 2)
  electricServiceFeeMode   ServiceFeeMode
  electricServiceFeeAmount Decimal     @db.Decimal(10, 2)

  rooms        Room[]        @relation("RoomDefaultRule")
  roomBillings RoomBilling[] @relation("RoomBillingRule")

  @@map("billing_rules")
}

// ============================================================================
// ROOM — matches Excel ROOM_MASTER sheet
// Primary key is roomNo (string), e.g. "798/1", "3201"
// ============================================================================

model Room {
  roomNo                String     @id  // e.g. "798/1", "3201"
  floorNo               Int
  defaultAccountId      String
  defaultRuleCode       String
  defaultRentAmount     Decimal    @db.Decimal(10, 2)
  hasFurniture          Boolean    @default(false)
  defaultFurnitureAmount Decimal   @db.Decimal(10, 2) @default(0)
  roomStatus            RoomStatus @default(ACTIVE)
  lineUserId            String?    // for tenant LINE messaging

  defaultAccount BankAccount @relation("RoomDefaultAccount", fields: [defaultAccountId], references: [id])
  defaultRule    BillingRule @relation("RoomDefaultRule", fields: [defaultRuleCode], references: [code])

  billings                  RoomBilling[]
  tenants                   RoomTenant[]
  contracts                 Contract[]
  invoices                  Invoice[]
  conversations             Conversation[]
  maintenanceTickets        MaintenanceTicket[]
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@index([floorNo])
  @@index([roomStatus])
  @@index([defaultAccountId])
  @@map("rooms")
}

// ============================================================================
// BILLING PERIOD — replaces BillingCycle
// One row = one calendar month
// ============================================================================

model BillingPeriod {
  id        String              @id @default(uuid())
  year      Int
  month     Int                 // 1-12
  status    BillingPeriodStatus @default(OPEN)
  dueDay    Int                 @default(25)  // day of month payment is due
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  roomBillings  RoomBilling[]
  importBatches ImportBatch[]

  @@unique([year, month])
  @@index([status])
  @@index([year, month])
  @@map("billing_periods")
}

// ============================================================================
// ROOM BILLING — replaces BillingRecord+BillingItem
// One row per room per billing period, directly maps to Excel floor sheet row
// ============================================================================

model RoomBilling {
  id               String            @id @default(uuid())
  billingPeriodId  String
  roomNo           String

  // Account: override or inherited from room default
  recvAccountOverrideId String?  // override set in Excel recv_account_override_id column
  recvAccountId         String   // effective account (override or default)

  // Rule: override or inherited from room default
  ruleOverrideCode String?  // override set in Excel rule_override_code column
  ruleCode         String   // effective rule code

  rentAmount Decimal @db.Decimal(10, 2)

  // Water meter
  waterMode            MeterMode
  waterPrev            Decimal?  @db.Decimal(10, 2)
  waterCurr            Decimal?  @db.Decimal(10, 2)
  waterUnitsManual     Decimal?  @db.Decimal(10, 2)
  waterUnits           Decimal   @db.Decimal(10, 2) @default(0)
  waterUsageCharge     Decimal   @db.Decimal(10, 2) @default(0)
  waterServiceFeeManual Decimal? @db.Decimal(10, 2)
  waterServiceFee      Decimal   @db.Decimal(10, 2) @default(0)
  waterTotal           Decimal   @db.Decimal(10, 2) @default(0)

  // Electric meter
  electricMode            MeterMode
  electricPrev            Decimal?  @db.Decimal(10, 2)
  electricCurr            Decimal?  @db.Decimal(10, 2)
  electricUnitsManual     Decimal?  @db.Decimal(10, 2)
  electricUnits           Decimal   @db.Decimal(10, 2) @default(0)
  electricUsageCharge     Decimal   @db.Decimal(10, 2) @default(0)
  electricServiceFeeManual Decimal? @db.Decimal(10, 2)
  electricServiceFee      Decimal   @db.Decimal(10, 2) @default(0)
  electricTotal           Decimal   @db.Decimal(10, 2) @default(0)

  furnitureFee Decimal @db.Decimal(10, 2) @default(0)
  otherFee     Decimal @db.Decimal(10, 2) @default(0)
  totalDue     Decimal @db.Decimal(10, 2) @default(0)

  note        String?
  checkNotes  String?  // computed warnings e.g. "WATER missing prev/curr"

  status    RoomBillingStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id])
  room          Room          @relation(fields: [roomNo], references: [roomNo])
  effectiveRule BillingRule   @relation("RoomBillingRule", fields: [ruleCode], references: [code])
  invoice       Invoice?

  @@unique([billingPeriodId, roomNo])
  @@index([billingPeriodId])
  @@index([roomNo])
  @@index([status])
  @@map("room_billings")
}

// ============================================================================
// INVOICE — simplified, 1:1 with RoomBilling
// ============================================================================

model Invoice {
  id            String        @id @default(uuid())
  roomBillingId String        @unique
  roomNo        String
  year          Int
  month         Int
  status        InvoiceStatus @default(GENERATED)
  totalAmount   Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  issuedAt      DateTime      @default(now())
  sentAt        DateTime?
  paidAt        DateTime?
  note          String?
  accessToken   String?       @unique  // for tenant PDF access link
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  roomBilling               RoomBilling                @relation(fields: [roomBillingId], references: [id])
  room                      Room                       @relation(fields: [roomNo], references: [roomNo])
  payments                  Payment[]
  paymentMatches            PaymentMatch[]
  paymentTransactions       PaymentTransaction[]       @relation("InvoicePaymentTransactions")
  deliveries                InvoiceDelivery[]
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@index([roomNo])
  @@index([year, month])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

// ============================================================================
// INVOICE DELIVERY — per-channel delivery tracking
// ============================================================================

model InvoiceDelivery {
  id           String                 @id @default(uuid())
  invoiceId    String
  channel      InvoiceDeliveryChannel
  status       InvoiceDeliveryStatus  @default(PENDING)
  recipientRef String?
  sentAt       DateTime?
  viewedAt     DateTime?
  errorMessage String?
  createdBy    String?

  documentTemplateId   String?
  documentTemplateHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([channel, status])
  @@map("invoice_deliveries")
}

// ============================================================================
// IMPORT BATCH — tracks Excel import history
// ============================================================================

model ImportBatch {
  id              String            @id @default(uuid())
  billingPeriodId String
  filename        String
  schemaVersion   String
  rowsTotal       Int
  rowsImported    Int
  rowsSkipped     Int
  rowsErrored     Int
  status          ImportBatchStatus
  errorLog        Json?
  importedBy      String
  createdAt       DateTime          @default(now())

  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id])

  @@index([billingPeriodId])
  @@index([status])
  @@map("import_batches")
}

// ============================================================================
// PAYMENT  (unchanged structure, FK updated to Invoice)
// ============================================================================

model Payment {
  id               String        @id @default(uuid())
  amount           Decimal       @db.Decimal(12, 2)
  paidAt           DateTime
  description      String?
  reference        String?
  sourceFile       String
  status           PaymentStatus @default(PENDING)
  matchedInvoiceId String?
  matchedAt        DateTime?
  confirmedAt      DateTime?
  confirmedBy      String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  matches  PaymentMatch[]
  invoices Invoice[]

  @@index([status])
  @@index([paidAt])
  @@index([amount])
  @@map("payments")
}

model PaymentTransaction {
  id              String                   @id @default(uuid())
  amount          Decimal                  @db.Decimal(12, 2)
  transactionDate DateTime
  description     String?
  reference       String?
  sourceFile      String
  status          PaymentTransactionStatus @default(PENDING)
  confidenceScore Decimal?                 @db.Decimal(3, 2)
  invoiceId       String?
  matchedAt       DateTime?
  confirmedAt     DateTime?
  confirmedBy     String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectReason    String?
  bankAccountId   String?
  matchedAmount   Decimal?                 @db.Decimal(12, 2)
  matchType       PaymentMatchType?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  invoice     Invoice?     @relation("InvoicePaymentTransactions", fields: [invoiceId], references: [id])
  bankAccount BankAccount? @relation("TransactionBankAccount", fields: [bankAccountId], references: [id])

  @@index([status])
  @@index([transactionDate])
  @@index([amount])
  @@index([reference])
  @@index([bankAccountId])
  @@map("payment_transactions")
}

model PaymentMatch {
  id            String             @id @default(uuid())
  paymentId     String
  invoiceId     String
  confidence    MatchConfidence
  matchCriteria Json?
  isAutoMatched Boolean            @default(false)
  status        PaymentMatchStatus @default(PENDING)
  confirmedAt   DateTime?
  confirmedBy   String?
  createdAt     DateTime           @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([status])
  @@map("payment_matches")
}

// ============================================================================
// TENANT MANAGEMENT
// ============================================================================

model Tenant {
  id               String   @id @default(uuid())
  lineUserId       String?
  firstName        String
  lastName         String
  phone            String
  email            String?
  emergencyContact String?
  emergencyPhone   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  roomTenants               RoomTenant[]
  contracts                 Contract[]                 @relation("PrimaryTenant")
  conversations             Conversation[]
  maintenanceTickets        MaintenanceTicket[]
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([lineUserId])
  @@index([phone])
  @@index([email])
  @@map("tenants")
}

model RoomTenant {
  id          String     @id @default(uuid())
  roomNo      String
  tenantId    String
  role        TenantRole
  moveInDate  DateTime
  moveOutDate DateTime?
  createdAt   DateTime   @default(now())

  room   Room   @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([roomNo, tenantId])
  @@index([roomNo])
  @@index([tenantId])
  @@index([role])
  @@map("room_tenants")
}

// ============================================================================
// CONTRACT MANAGEMENT
// ============================================================================

model Contract {
  id                String         @id @default(uuid())
  roomNo            String
  primaryTenantId   String
  startDate         DateTime
  endDate           DateTime
  monthlyRent       Decimal        @db.Decimal(10, 2)
  deposit           Decimal?       @db.Decimal(10, 2)
  furnitureFee      Decimal?       @db.Decimal(10, 2)
  status            ContractStatus @default(ACTIVE)
  terminationDate   DateTime?
  terminationReason String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  room                      Room                       @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  primaryTenant             Tenant                     @relation("PrimaryTenant", fields: [primaryTenantId], references: [id], onDelete: Restrict)
  generatedDocuments        GeneratedDocument[]
  documentGenerationTargets DocumentGenerationTarget[]

  @@unique([roomNo, status])
  @@index([status])
  @@index([primaryTenantId])
  @@index([startDate])
  @@index([endDate])
  @@map("contracts")
}

// ============================================================================
// MESSAGING
// ============================================================================

model LineUser {
  id            String    @id @default(uuid())
  lineUserId    String    @unique
  displayName   String
  pictureUrl    String?
  statusMessage String?
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]

  @@map("line_users")
}

model Conversation {
  id            String             @id @default(uuid())
  lineUserId    String
  tenantId      String?
  roomNo        String?
  lastMessageAt DateTime
  unreadCount   Int                @default(0)
  status        ConversationStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  lineUser LineUser  @relation(fields: [lineUserId], references: [lineUserId])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  room     Room?     @relation(fields: [roomNo], references: [roomNo])
  messages Message[]

  @@unique([lineUserId])
  @@index([tenantId])
  @@index([roomNo])
  @@index([unreadCount])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  lineMessageId  String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String
  metadata       Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  sentAt         DateTime
  receivedAt     DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([lineMessageId])
  @@index([conversationId])
  @@index([direction])
  @@index([sentAt])
  @@index([conversationId, sentAt])
  @@map("messages")
}

model Notification {
  id            String             @id @default(uuid())
  type          NotificationType
  roomNo        String
  tenantId      String
  scheduledAt   DateTime
  sentAt        DateTime?
  status        NotificationStatus @default(PENDING)
  content       String
  lineMessageId String?
  errorMessage  String?
  createdAt     DateTime           @default(now())

  @@index([roomNo])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

model MessageTemplate {
  id        String              @id @default(uuid())
  name      String
  type      MessageTemplateType @default(CUSTOM)
  body      String              @db.Text
  variables String[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([type])
  @@map("message_templates")
}

// ============================================================================
// FILES
// ============================================================================

model UploadedFile {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  size         Int
  storageKey   String   @unique
  url          String
  uploadedBy   String?
  createdAt    DateTime @default(now())

  templateVersions             DocumentTemplateVersion[] @relation("TemplateVersionSourceFile")
  generatedDocumentFiles       GeneratedDocumentFile[]
  documentGenerationJobBundles DocumentGenerationJob[]   @relation("GenerationJobBundleFile")

  @@index([createdAt])
  @@map("uploaded_files")
}

// ============================================================================
// MAINTENANCE
// ============================================================================

model MaintenanceTicket {
  id              String              @id @default(uuid())
  roomNo          String
  tenantId        String
  title           String
  description     String
  priority        MaintenancePriority @default(MEDIUM)
  status          MaintenanceStatus   @default(OPEN)
  assignedStaffId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  room        Room                    @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  comments    MaintenanceComment[]
  attachments MaintenanceAttachment[]

  @@index([roomNo])
  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_tickets")
}

model MaintenanceComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  message   String
  createdAt DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("maintenance_comments")
}

model MaintenanceAttachment {
  id        String   @id @default(uuid())
  ticketId  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("maintenance_attachments")
}

// ============================================================================
// AUDIT
// ============================================================================

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  userName   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// CONFIG
// ============================================================================

model Config {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@map("configs")
}

// ============================================================================
// OUTBOX
// ============================================================================

model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  retryCount    Int       @default(0)
  lastError     String?

  @@index([processedAt])
  @@index([aggregateType, aggregateId])
  @@index([processedAt, createdAt])
  @@index([eventType])
  @@index([retryCount])
  @@map("outbox_events")
}

// ============================================================================
// ADMIN AUTH
// ============================================================================

model AdminUser {
  id                  String    @id @default(uuid())
  username            String    @unique
  email               String?   @unique
  displayName         String
  role                AdminRole @default(STAFF)
  passwordHash        String
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  resetTokens PasswordResetToken[]

  @@index([role])
  @@index([isActive])
  @@map("admin_users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model StaffRegistrationRequest {
  id           String                  @id @default(uuid())
  username     String
  email        String?
  displayName  String
  passwordHash String
  status       StaffRegistrationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([username, status])
  @@unique([email, status])
  @@index([status])
  @@index([createdAt])
  @@map("staff_registration_requests")
}

// ============================================================================
// TENANT REGISTRATION (LINE bot flow)
// ============================================================================

model TenantRegistration {
  id               String                   @id @default(uuid())
  lineUserId       String                   @unique
  lineDisplayName  String?
  phone            String?
  claimedRoom      String?
  status           TenantRegistrationStatus @default(PENDING)
  rejectionReason  String?
  correctionNote   String?
  resolvedRoomNo   String?
  resolvedTenantId String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([status])
  @@index([lineUserId])
  @@map("tenant_registrations")
}

// ============================================================================
// DOCUMENT TEMPLATES
// ============================================================================

model DocumentTemplate {
  id              String                 @id @default(uuid())
  name            String
  type            DocumentTemplateType   @default(INVOICE)
  description     String?
  status          DocumentTemplateStatus @default(DRAFT)
  subject         String?
  body            String                 @db.Text
  activeVersionId String?
  createdById     String?
  updatedById     String?
  archivedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  activeVersion      DocumentTemplateVersion?          @relation("ActiveTemplateVersion", fields: [activeVersionId], references: [id])
  versions           DocumentTemplateVersion[]         @relation("TemplateVersions")
  fieldDefinitions   DocumentTemplateFieldDefinition[]
  generationJobs     DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]

  @@index([type])
  @@index([status])
  @@index([type, status])
  @@map("document_templates")
}

model DocumentTemplateVersion {
  id            String                        @id @default(uuid())
  templateId    String
  version       Int
  label         String?
  subject       String?
  body          String                        @db.Text
  status        DocumentTemplateVersionStatus @default(DRAFT)
  fileType      String                        @default("html")
  fileName      String?
  storageKey    String?
  checksum      String?
  sourceFileId  String?
  createdById   String?
  activatedById String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  meta          Json?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  template           DocumentTemplate        @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  activeForTemplates DocumentTemplate[]      @relation("ActiveTemplateVersion")
  sourceFile         UploadedFile?           @relation("TemplateVersionSourceFile", fields: [sourceFileId], references: [id])
  generationJobs     DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@index([sourceFileId])
  @@map("document_template_versions")
}

model DocumentTemplateFieldDefinition {
  id           String                 @id @default(uuid())
  templateId   String
  key          String
  label        String
  category     DocumentFieldCategory
  valueType    DocumentFieldValueType
  path         String
  description  String?
  sampleValue  String?
  isRequired   Boolean                @default(false)
  isCollection Boolean                @default(false)
  sortOrder    Int                    @default(0)
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, category, sortOrder])
  @@map("document_template_field_definitions")
}

model DocumentGenerationJob {
  id                String                      @id @default(uuid())
  templateId        String
  templateVersionId String
  requestedById     String?
  billingPeriodId   String?
  year              Int?
  month             Int?
  scope             DocumentSourceScope
  selection         Json?
  dryRun            Boolean                     @default(false)
  status            DocumentGenerationJobStatus @default(QUEUED)
  totalRequested    Int                         @default(0)
  successCount      Int                         @default(0)
  skippedCount      Int                         @default(0)
  failedCount       Int                         @default(0)
  errorMessage      String?
  bundleFileId      String?
  createdAt         DateTime                    @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  updatedAt         DateTime                    @updatedAt

  template        DocumentTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion DocumentTemplateVersion    @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  bundleFile      UploadedFile?              @relation("GenerationJobBundleFile", fields: [bundleFileId], references: [id])
  targets         DocumentGenerationTarget[]
  generatedDocuments GeneratedDocument[]

  @@index([templateId, createdAt])
  @@index([templateVersionId])
  @@index([billingPeriodId])
  @@index([status])
  @@map("document_generation_jobs")
}

model DocumentGenerationTarget {
  id                  String                         @id @default(uuid())
  jobId               String
  roomNo              String
  roomBillingId       String?
  invoiceId           String?
  contractId          String?
  tenantId            String?
  status              DocumentGenerationTargetStatus @default(PENDING)
  generatedDocumentId String?
  reason              String?
  renderSummary       Json?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  job      DocumentGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  room     Room                  @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  invoice  Invoice?              @relation(fields: [invoiceId], references: [id])
  contract Contract?             @relation(fields: [contractId], references: [id])
  tenant   Tenant?               @relation(fields: [tenantId], references: [id])

  @@unique([jobId, roomNo])
  @@index([status])
  @@index([generatedDocumentId])
  @@map("document_generation_targets")
}

model GeneratedDocument {
  id                String                  @id @default(uuid())
  templateId        String
  templateVersionId String
  generationJobId   String?
  documentType      DocumentTemplateType
  status            GeneratedDocumentStatus @default(GENERATED)
  title             String
  subject           String?
  sourceScope       DocumentSourceScope
  roomNo            String
  billingPeriodId   String?
  roomBillingId     String?
  invoiceId         String?
  contractId        String?
  tenantId          String?
  year              Int?
  month             Int?
  documentVersion   Int                     @default(1)
  generatedById     String?
  renderContext     Json?
  validation        Json?
  generatedAt       DateTime                @default(now())
  archivedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  template        DocumentTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion DocumentTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  generationJob   DocumentGenerationJob?  @relation(fields: [generationJobId], references: [id])
  room            Room                    @relation(fields: [roomNo], references: [roomNo], onDelete: Cascade)
  invoice         Invoice?                @relation(fields: [invoiceId], references: [id])
  contract        Contract?               @relation(fields: [contractId], references: [id])
  tenant          Tenant?                 @relation(fields: [tenantId], references: [id])
  files           GeneratedDocumentFile[]

  @@index([templateId, generatedAt])
  @@index([templateVersionId])
  @@index([roomNo, year, month])
  @@index([billingPeriodId])
  @@index([roomBillingId])
  @@index([status])
  @@map("generated_documents")
}

model GeneratedDocumentFile {
  id                  String                    @id @default(uuid())
  generatedDocumentId String
  uploadedFileId      String
  role                GeneratedDocumentFileRole
  format              String
  isPrimary           Boolean                   @default(false)
  createdAt           DateTime                  @default(now())

  generatedDocument GeneratedDocument @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)
  uploadedFile      UploadedFile      @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([generatedDocumentId, role])
  @@index([uploadedFileId])
  @@map("generated_document_files")
}
