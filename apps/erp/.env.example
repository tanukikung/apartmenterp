# =============================================================================
# Apartment ERP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#
#   cp .env.example .env
#
# [REQUIRED] = must set before the app will start
# [optional] = has a sensible default or falls back gracefully
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL 15+ connection string.
# Generate password: openssl rand -hex 16
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/apartment_erp"

# -----------------------------------------------------------------------------
# AUTHENTICATION  [REQUIRED]
# -----------------------------------------------------------------------------
# Random secret used to sign and verify session tokens.
# ⚠️  NEVER use the same secret in production as in development!
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Canonical URL of the app — no trailing slash.
#   Dev:  http://localhost:3001
#   Prod: https://your-domain.com
NEXTAUTH_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV="development"

# Used by server-side fetch calls and OnlyOffice callbacks. Same as NEXTAUTH_URL.
APP_BASE_URL="http://localhost:3001"

# Secret added to scheduled job webhook requests for authentication.
# Generate: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_openssl_rand_hex_32"

# -----------------------------------------------------------------------------
# LINE MESSAGING API  [optional — required for tenant LINE chat integration]
# -----------------------------------------------------------------------------
# Create a channel at https://developers.line.biz/
# Leave blank to disable LINE features (chat/notifications/registrations).
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_ACCESS_TOKEN=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""

# -----------------------------------------------------------------------------
# REDIS  [optional — recommended for production]
# -----------------------------------------------------------------------------
# Enables: background job status tracking, outbox event persistence.
# Falls back to in-memory storage when not set (resets on restart).
#
# Start locally: docker compose up -d redis
# Or install natively: https://redis.io/docs/install/
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# ONLYOFFICE DOCUMENT SERVER  [optional — required for visual template editing]
# -----------------------------------------------------------------------------
# Provides an in-browser word processor for editing invoice/contract templates.
# Without it, you can still upload raw HTML files as template versions.
#
# Start locally:  docker compose up -d onlyoffice
# Free community edition: https://github.com/ONLYOFFICE/DocumentServer
#
# URL that the BROWSER uses to load the OnlyOffice JS (visible from client).
ONLYOFFICE_DOCUMENT_SERVER_URL="http://localhost:8080"

# JWT secret — must match the JWT_SECRET set in the OnlyOffice container.
# Generate: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET="REPLACE_WITH_openssl_rand_hex_32"

# URL that the OnlyOffice Docker container uses to call back into the ERP.
# Docker containers cannot reach "localhost" on the host — use host.docker.internal.
#   Local Docker:       http://host.docker.internal:3001
#   Docker Compose:     http://app:3000   (internal compose service name)
#   Production:         leave blank → APP_BASE_URL is used automatically
ONLYOFFICE_CALLBACK_BASE_URL="http://host.docker.internal:3001"
