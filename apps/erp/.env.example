# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/apartment_erp?schema=public"

# LINE API
LINE_CHANNEL_ID="your_line_channel_id"
LINE_CHANNEL_SECRET="your_line_channel_secret"
LINE_ACCESS_TOKEN="your_line_access_token"
LINE_CHANNEL_ACCESS_TOKEN="your_line_access_token"
LINE_USER_ID="your_line_bot_user_id"

# Authentication
NEXTAUTH_SECRET="your_nextauth_secret_generate_with_openssl"
NEXTAUTH_URL="http://localhost:3000"

# Application
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
CRON_SECRET="set_a_strong_random_secret"

# Redis (optional for caching/queues)
REDIS_URL="redis://redis:6379"

# ONLYOFFICE Document Server
# Set ONLYOFFICE_DOCUMENT_SERVER_URL to your running ONLYOFFICE instance.
# If not set, the editor will be unavailable but the rest of the app works normally.
ONLYOFFICE_DOCUMENT_SERVER_URL="http://localhost:8080"
# Shared JWT secret — must match JWT_SECRET in the ONLYOFFICE container.
# Generate with: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET="your_onlyoffice_jwt_secret"
