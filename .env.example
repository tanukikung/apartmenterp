# ได้จาก LINE Developers Console: https://developers.line.biz
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
