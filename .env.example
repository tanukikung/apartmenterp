# ================================================================
# Apartment ERP — Environment Variables
# ================================================================
# 1. Copy this file:  cp .env.example .env   (Linux/Mac)
#                     copy .env.example .env  (Windows)
# 2. Fill in every value marked [REQUIRED]
# 3. Run: docker compose up -d
# ================================================================

# ── Server Address ───────────────────────────────────────────────
# Local machine:  localhost
# VPS/Remote:     your server's IP address (e.g. 192.168.1.100)
APP_HOST=localhost
APP_PORT=3001

# ── Database [REQUIRED] ──────────────────────────────────────────
# Use a strong password — no spaces or special shell characters
DB_PASSWORD=CHANGE_THIS_DB_PASSWORD

# ── Redis [REQUIRED] ─────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ── Authentication [REQUIRED] ────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_THIS_NEXTAUTH_SECRET

# ── OnlyOffice Document Editor [REQUIRED] ────────────────────────
ONLYOFFICE_PORT=8080
# Generate: openssl rand -base64 32  (must match JWT_SECRET in container)
ONLYOFFICE_JWT_SECRET=CHANGE_THIS_ONLYOFFICE_SECRET

# ── Cron Jobs [optional] ─────────────────────────────────────────
CRON_SECRET=CHANGE_THIS_CRON_SECRET

# ── LINE Integration [optional] ──────────────────────────────────
# Leave empty to disable. Get credentials from LINE Developers Console.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
