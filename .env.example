# =============================================================================
# Apartment ERP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#
#   cp .env.example .env
#
# [REQUIRED]  = must be set before the app will start correctly
# [OPTIONAL]  = has a sensible default or is not required for core features
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL 15+ connection string.
# Generate password: openssl rand -hex 16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/test"

# -----------------------------------------------------------------------------
# AUTHENTICATION  [REQUIRED]
# -----------------------------------------------------------------------------
# Random secret used to sign and verify session tokens.
# NEVER use the same secret in production as in development!
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Canonical URL of the app — no trailing slash.
#   Dev:  http://localhost:3001
#   Prod: https://your-domain.com
NEXTAUTH_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# SENTRY ERROR TRACKING  [OPTIONAL]
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking. When empty the app runs without Sentry.
# Get yours at: https://sentry.io
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV="development"

# Used by server-side fetch calls. Same as NEXTAUTH_URL.
APP_BASE_URL="http://localhost:3001"

# Secret added to scheduled job webhook requests for authentication.
# Generate: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_openssl_rand_hex_32"

# -----------------------------------------------------------------------------
# LINE MESSAGING API  [OPTIONAL — required for tenant LINE chat integration]
# -----------------------------------------------------------------------------
# Create a channel at https://developers.line.biz/
# Without LINE credentials the chat, notifications and registration features
# are unavailable, but all other parts of the ERP work normally.
#
# GETTING YOUR CREDENTIALS:
#   1. Go to https://developers.line.biz/console/
#   2. Create a Messaging API channel
#   3. Basic settings tab → Channel ID and Channel Secret
#   4. Messaging API tab → Long-lived access token (or generate short-lived)
#
# TOKEN FALLBACK RELATIONSHIP:
#   The LINE SDK accepts ONE access token. The system resolves it as:
#
#     1. LINE_ACCESS_TOKEN          — primary token variable (new deployments)
#     2. LINE_CHANNEL_ACCESS_TOKEN  — fallback / legacy variable
#
#   If LINE_ACCESS_TOKEN is set to a non-empty string, that token is used.
#   If LINE_ACCESS_TOKEN is empty (""), the SDK falls through to
#     LINE_CHANNEL_ACCESS_TOKEN — if that is non-empty, it is used.
#   If BOTH are empty or unset, LINE is unavailable.
#
#   Therefore: set LINE_ACCESS_TOKEN="" (or leave it blank) to delegate to
#   LINE_CHANNEL_ACCESS_TOKEN. Setting LINE_ACCESS_TOKEN="" does NOT mean
#   "disabled" — it means "use the fallback token instead".
#
# LINE_CHANNEL_ID:    Your LINE channel ID (e.g., 1234567890)
LINE_CHANNEL_ID=""
# LINE_CHANNEL_SECRET: Found in LINE Developers Console → Basic settings → Channel secret
LINE_CHANNEL_SECRET=""
# LINE_ACCESS_TOKEN:    Long-lived access token from Messaging API tab (primary)
LINE_ACCESS_TOKEN=""
# LINE_CHANNEL_ACCESS_TOKEN: Legacy fallback token (used if LINE_ACCESS_TOKEN is empty)
LINE_CHANNEL_ACCESS_TOKEN=""
# LINE_USER_ID:        Your LINE user ID for testing (optional)
LINE_USER_ID=""

# -----------------------------------------------------------------------------
# REDIS  [OPTIONAL — recommended for production, optional for development]
# -----------------------------------------------------------------------------
# Enables: background job status tracking, outbox event persistence.
# When not set, the app falls back to in-memory storage (resets on restart).
#
# Start locally with Docker: docker compose up -d redis
# Or install natively:        https://redis.io/docs/install/
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# DATABASE BACKUP  [OPTIONAL — requires pg_dump + gzip on PATH]
# -----------------------------------------------------------------------------
# Cron schedule for automatic backups (default: 3am daily).
# Crontab format: minute hour day-of-month month day-of-week
BACKUP_CRON="0 3 * * *"

# How many days to keep local and S3 backups before deleting.
BACKUP_RETENTION_DAYS="7"

# ── S3 Backup Upload ──────────────────────────────────────────────────────────
# When BACKUP_S3_BUCKET is set, backups are uploaded to S3 after creation.
# Without S3 credentials, backups are stored locally only.
#
# SETUP STEPS:
#   1. Create an S3 bucket (e.g., my-apartment-erp-backups)
#   2. Create an IAM user with programmatic access
#   3. Attach this inline policy (replace BUCKET_NAME):
#
# {
#   "Version": "2012-10-17",
#   "Statement": [{
#     "Effect": "Allow",
#     "Action": ["s3:PutObject", "s3:ListBucket", "s3:DeleteObject"],
#     "Resource": [
#       "arn:aws:s3:::BUCKET_NAME",
#       "arn:aws:s3:::BUCKET_NAME/backups/*"
#     ]
#   }]
# }
#
# Required environment variables:
# BACKUP_S3_BUCKET:      S3 bucket name (e.g., my-apartment-erp-backups)
# AWS_ACCESS_KEY_ID:     IAM access key ID
# AWS_SECRET_ACCESS_KEY: IAM secret access key
# AWS_REGION:            Bucket region (e.g., ap-southeast-1 for Singapore)
BACKUP_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
