# =============================================================================
# Apartment ERP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#
#   cp .env.example .env
#
# [REQUIRED]  = must be set before the app will start correctly
# [OPTIONAL]  = has a sensible default or is not required for core features
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL 15+ connection string.
# Generate password: openssl rand -hex 16
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/test"

# PostgreSQL container configuration (used by docker-compose.prod.yml)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME_secure_password"
POSTGRES_DB="test"
POSTGRES_PORT="5432"

# -----------------------------------------------------------------------------
# AUTHENTICATION  [REQUIRED]
# -----------------------------------------------------------------------------
# Random secret used to sign and verify session tokens.
# NEVER use the same secret in production as in development!
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Canonical URL of the app — no trailing slash.
#   Dev:  http://localhost:3001
#   Prod: https://your-domain.com
NEXTAUTH_URL="http://localhost:3001"

# Application port (used by docker-compose.prod.yml)
APP_PORT="3000"

# -----------------------------------------------------------------------------
# SENTRY ERROR TRACKING  [OPTIONAL]
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking. When empty the app runs without Sentry.
# Get yours at: https://sentry.io
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV="development"

# Used by server-side fetch calls. Same as NEXTAUTH_URL.
APP_BASE_URL="http://localhost:3001"

# Secret added to scheduled job webhook requests for authentication.
# Generate: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_openssl_rand_hex_32"

# -----------------------------------------------------------------------------
# LINE MESSAGING API  [OPTIONAL — required for tenant LINE chat integration]
# -----------------------------------------------------------------------------
# Create a channel at https://developers.line.biz/
# Without LINE credentials the chat, notifications and registration features
# are unavailable, but all other parts of the ERP work normally.
#
# GETTING YOUR CREDENTIALS:
#   1. Go to https://developers.line.biz/console/
#   2. Create a Messaging API channel
#   3. Basic settings tab → Channel ID and Channel Secret
#   4. Messaging API tab → Long-lived access token (or generate short-lived)
#
# TOKEN FALLBACK RELATIONSHIP:
#   The LINE SDK accepts ONE access token. The system resolves it as:
#
#     1. LINE_ACCESS_TOKEN          — primary token variable (new deployments)
#     2. LINE_CHANNEL_ACCESS_TOKEN  — fallback / legacy variable
#
#   If LINE_ACCESS_TOKEN is set to a non-empty string, that token is used.
#   If LINE_ACCESS_TOKEN is empty (""), the SDK falls through to
#     LINE_CHANNEL_ACCESS_TOKEN — if that is non-empty, it is used.
#   If BOTH are empty or unset, LINE is unavailable.
#
#   Therefore: set LINE_ACCESS_TOKEN="" (or leave it blank) to delegate to
#   LINE_CHANNEL_ACCESS_TOKEN. Setting LINE_ACCESS_TOKEN="" does NOT mean
#   "disabled" — it means "use the fallback token instead".
#
# LINE_CHANNEL_ID:    Your LINE channel ID (e.g., 1234567890)
LINE_CHANNEL_ID=""
# LINE_CHANNEL_SECRET: Found in LINE Developers Console → Basic settings → Channel secret
LINE_CHANNEL_SECRET=""
# LINE_ACCESS_TOKEN:    Long-lived access token from Messaging API tab (primary)
LINE_ACCESS_TOKEN=""
# LINE_CHANNEL_ACCESS_TOKEN: Legacy fallback token (used if LINE_ACCESS_TOKEN is empty)
LINE_CHANNEL_ACCESS_TOKEN=""
# LINE_USER_ID:        Your LINE user ID for testing (optional)
LINE_USER_ID=""

# -----------------------------------------------------------------------------
# REDIS  [OPTIONAL — recommended for production, optional for development]
# -----------------------------------------------------------------------------
# Enables: background job status tracking, outbox event persistence.
# When not set, the app falls back to in-memory storage (resets on restart).
#
# Start locally with Docker: docker compose up -d redis
# Or install natively:        https://redis.io/docs/install/
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# DATABASE BACKUP  [OPTIONAL — requires pg_dump + gzip on PATH]
# -----------------------------------------------------------------------------
# Cron schedule for automatic backups (default: 3am daily).
# Crontab format: minute hour day-of-month month day-of-week
BACKUP_CRON="0 3 * * *"

# How many days to keep local and S3 backups before deleting.
BACKUP_RETENTION_DAYS="7"

# ── S3 Backup Upload ──────────────────────────────────────────────────────────
# When BACKUP_S3_BUCKET is set, backups are uploaded to S3 after creation.
# Without S3 credentials, backups are stored locally only.
#
# SETUP STEPS:
#   1. Create an S3 bucket (e.g., my-apartment-erp-backups)
#   2. Create an IAM user with programmatic access
#   3. Attach this inline policy (replace BUCKET_NAME):
#
# {
#   "Version": "2012-10-17",
#   "Statement": [{
#     "Effect": "Allow",
#     "Action": ["s3:PutObject", "s3:ListBucket", "s3:DeleteObject"],
#     "Resource": [
#       "arn:aws:s3:::BUCKET_NAME",
#       "arn:aws:s3:::BUCKET_NAME/backups/*"
#     ]
#   }]
# }
#
# Required environment variables:
# BACKUP_S3_BUCKET:      S3 bucket name (e.g., my-apartment-erp-backups)
# AWS_ACCESS_KEY_ID:     IAM access key ID
# AWS_SECRET_ACCESS_KEY: IAM secret access key
# AWS_REGION:            Bucket region (e.g., ap-southeast-1 for Singapore)
BACKUP_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
# ──────────────────────────────────────────────────────────────────
# Apartment ERP — Production Environment Variables
# Copy this file to .env.production and fill in all REQUIRED values
# before deploying. Variables marked # REQUIRED: MUST be set.
# ──────────────────────────────────────────────────────────────────

# REQUIRED: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/apartment_erp"

# REQUIRED: Authentication secret (min 32 chars)
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_WITH_32_CHAR_MINIMUM_random_secret"

# REQUIRED: Public URL of this deployment (no trailing slash)
# Example: https://erp.yourdomain.com
APP_BASE_URL="https://your-domain.com"

# ── Auth ──────────────────────────────────────────────────────────
# Set true in production (HTTPS only)
COOKIE_SECURE=true
NODE_ENV=production
NEXTAUTH_URL="${APP_BASE_URL}"

# Optional: require a code for new admin sign-ups
# ADMIN_SIGNUP_CODE="your-signup-code"

# ── LINE Messaging API ────────────────────────────────────────────
# REQUIRED if using LINE notifications. Get from LINE Developers console.
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_ACCESS_TOKEN=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""

# ── Cron / Background Jobs ────────────────────────────────────────
# REQUIRED if calling cron endpoints externally (e.g. external scheduler)
# Generate with: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_openssl_rand_hex_32"
CRON_ENABLED=true
OUTBOX_ENABLED=true

# ── Redis (optional) ───────────────────────────────────────────────
# Only needed if using Redis for outbox/session caching
REDIS_URL=""

# ── Database Backup ────────────────────────────────────────────────
BACKUP_CRON="0 3 * * *"
BACKUP_RETENTION_DAYS="7"

# ── AWS S3 Backup ─────────────────────────────────────────────────
# REQUIRED if using S3 backup feature
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
BACKUP_S3_BUCKET=""
# Optional S3 endpoint for S3-compatible services (MinIO, R2, etc.)
# S3_ENDPOINT=""
# S3_FORCE_PATH_STYLE=""

# ── Sentry Error Tracking ──────────────────────────────────────────
# Optional. Leave empty to disable Sentry.
SENTRY_DSN=""

# ── Document Retention Policy ─────────────────────────────────────
DOCUMENT_RETENTION_DAYS=90
ARCHIVE_BEFORE_DELETE_DAYS=30
ARCHIVE_NOTIFY_DAYS_BEFORE=7

# ── File Storage ───────────────────────────────────────────────────
# local = store uploads on filesystem (default)
# s3    = store uploads in S3 bucket
STORAGE_DRIVER=local
UPLOAD_DIR="/var/apartment-erp/uploads"

# ── OnlyOffice Document Server ────────────────────────────────────
# Required if using document generation/editing features
ONLYOFFICE_ENABLED=false
ONLYOFFICE_DOCUMENT_SERVER_URL=""
ONLYOFFICE_JWT_SECRET=""
ONLYOFFICE_CALLBACK_BASE_URL=""

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_DIR="/var/log/apartment-erp"
DATABASE_URL="postgresql://test:test@localhost:5432/apartment_test"
NODE_ENV="test"
INVOICE_ACCESS_SECRET="test-invoice-access-secret-for-testing-only"
FILE_ACCESS_SECRET="test-file-access-secret-for-testing-only"
AUTH_SECRET="test-auth-secret-for-testing-only-minimum-32-chars"
NEXTAUTH_SECRET="test-nextauth-secret-for-testing-only"
COOKIE_SECURE="false"
﻿# Customer deployment template for Docker Compose.
# The init script will create .env.customer from this file and generate secrets.

# Public app URL. Keep http://localhost:3000 for a local install.
# When deploying behind HTTPS, change this to your final domain.
APP_BASE_URL=http://localhost:3000

# Port exposed on the host machine.
APP_PORT=3000

# Container time zone for logs, scheduled jobs, and backup timestamps.
TZ=Asia/Bangkok

# Embedded PostgreSQL configuration.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=47cc53ee6ea41a44638990f954ad24fb20a8
POSTGRES_DB=apartment_erp

# Session and cron secrets. The init script generates strong random values.
NEXTAUTH_SECRET=ba657a33a8cf322c52356db74d41c143915a2b21a2c37eaceba7142474269a25
CRON_SECRET=60bcadab89df726c1cf05112a42d5d4df900c34c325ccfffc8c0a342b0d54211
INVOICE_ACCESS_SECRET=08ef7cb05f16646770b5d5f5b7e0a6f1d03ddd1fe076727af512df2ad662cb3b
FILE_ACCESS_SECRET=ba915b901619ff5236598a379f5d54431dad3d9a05b792bcbe41018ab33f62a8
SEED_OWNER_PASSWORD=1c881d11cacff7efa41e8be8
SEED_STAFF_PASSWORD=cddce70da1c147ebdc5305ce

# Core runtime flags.
COOKIE_SECURE=false
