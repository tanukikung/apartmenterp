# =============================================================================
# Apartment ERP — Environment Variables
# =============================================================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าที่จำเป็น:
#   cp .env.example .env

# =============================================================================
# REQUIRED — ต้องกรอกก่อนรันระบบ
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/test"

# Secret key สำหรับ sign session tokens
# สร้างได้ด้วย: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# URL ของระบบ (ไม่มี / ต่อท้าย)
NEXTAUTH_URL="http://localhost:3001"
APP_BASE_URL="http://localhost:3001"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

NODE_ENV="development"
COOKIE_SECURE=false
CRON_ENABLED=true
OUTBOX_ENABLED=true

# Secret สำหรับ cron webhook (ถ้ามี external scheduler)
CRON_SECRET="dev-cron-secret"

# Bearer token สำหรับ /api/metrics (เปิด public ถ้าไม่ใส่)
# METRICS_TOKEN=""

# =============================================================================
# FILE ACCESS — secrets สำหรับ download links
# =============================================================================
INVOICE_ACCESS_SECRET="dev-invoice-access-secret"
FILE_ACCESS_SECRET="dev-file-access-secret"
AUTH_SECRET="dev-auth-secret-minimum-32-chars"

# =============================================================================
# REDIS [OPTIONAL] — ไม่ใส่ก็ได้ ใช้ in-memory แทน
# =============================================================================
# For local dev (host mode): redis://localhost:6379
# For Docker: redis://redis:6379/1 (use service name "redis")
REDIS_URL="redis://localhost:6379"

# =============================================================================
# Docker — for docker-compose.yml (used by `docker compose up`)
# =============================================================================
# Override these to change external ports if defaults are taken:
# POSTGRES_PORT=5433   (internal always 5432)
# REDIS_PORT=6380      (internal always 6379)
# APP_PORT=3002        (internal always 3001)
# NOTE: Default ports 5432/6379/3001 may be taken by other services.
#       Docker Compose maps external:internal so HOST port 5433 → container 5432.

# =============================================================================
# LINE MESSAGING API [OPTIONAL] — ถ้าไม่ใช้ LINE ข้ามได้เลย
# =============================================================================
# ได้จาก https://developers.line.biz/console/
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_ACCESS_TOKEN=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""

# =============================================================================
# SENTRY ERROR TRACKING [OPTIONAL]
# =============================================================================
# ได้จาก https://sentry.io — ไม่ใส่ก็ได้
SENTRY_DSN=""

# =============================================================================
# DOCUMENT RETENTION
# =============================================================================
DOCUMENT_RETENTION_DAYS=90
ARCHIVE_BEFORE_DELETE_DAYS=30
ARCHIVE_NOTIFY_DAYS_BEFORE=7

# =============================================================================
# BACKUP [OPTIONAL]
# =============================================================================
BACKUP_CRON="0 3 * * *"
BACKUP_RETENTION_DAYS="7"